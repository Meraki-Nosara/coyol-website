---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href="/images/favicon.jpg" />
    <meta name="description" content="Sistema de control financiero para restaurantes Meraki" />
    <title>{title} | Meraki Control</title>
  </head>
  <body class="min-h-screen bg-landrover-alaska text-landrover-santorini">
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
