---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const images = [
  // Mix of real photos - lifestyle, activities, homes
  { src: '/images/gallery/land-rover-vintage.jpg', title: 'Vintage Land Rover', category: 'lifestyle' },
  { src: '/images/gallery/clay-court-aerial.jpg', title: 'Clay Court Aerial', category: 'activities' },
  { src: '/images/gallery/lifestyle-1.jpg', title: 'Modern Living', category: 'homes' },
  { src: '/images/gallery/saddle-detail.jpg', title: 'English Saddle', category: 'activities' },
  
  { src: '/images/gallery/lifestyle-2.jpg', title: 'Jungle Setting', category: 'lifestyle' },
  { src: '/images/gallery/equestrian-training.jpg', title: 'Equestrian Training', category: 'activities' },
  { src: '/images/gallery/firepit-friends.jpg', title: 'Evening Firepit', category: 'lifestyle' },
  { src: '/images/gallery/lifestyle-3.jpg', title: 'Tropical Life', category: 'lifestyle' },
  { src: '/images/gallery/farrier-horseshoe.jpg', title: 'Master Farrier', category: 'activities' },
  
  { src: '/images/gallery/lifestyle-5.jpg', title: 'Horseback Riding', category: 'activities' },
  
  { src: '/images/gallery/lifestyle-6.jpg', title: 'Family Time', category: 'lifestyle' },
  
  { src: '/images/gallery/lifestyle-7.jpg', title: 'Evening Light', category: 'lifestyle' },
  { src: '/images/gallery/tennis-aerial.jpg', title: 'Tennis Aerial', category: 'activities' },
  { src: '/images/gallery/lifestyle-8.jpg', title: 'Ranch Life', category: 'lifestyle' },
  
  { src: '/images/gallery/lifestyle-9.jpg', title: 'Sunset Views', category: 'lifestyle' },
  
  { src: '/images/gallery/lifestyle-10.jpg', title: 'Morning Ritual', category: 'lifestyle' },
  { src: '/images/gallery/construction-frame.jpg', title: 'Building Dreams', category: 'homes' },
  { src: '/images/gallery/lifestyle-11.jpg', title: 'Outdoor Living', category: 'lifestyle' },
  { src: '/images/gallery/DJI_20250326172154_0413_D.jpg', title: 'Coastal Views', category: 'lifestyle' },
  { src: '/images/gallery/lifestyle-12.jpg', title: 'Golden Hour', category: 'lifestyle' },
  { src: '/images/gallery/DJI_20250326172126_0411_D.jpg', title: 'Beach Aerial', category: 'lifestyle' },
  { src: '/images/gallery/IMG_3662.jpg', title: 'Family Moment', category: 'lifestyle' },
  { src: '/images/gallery/DJI_20250326130411_0403_D.jpg', title: 'Mountain Views', category: 'lifestyle' },
  { src: '/images/gallery/brass-hardware.jpg', title: 'Brass Detail', category: 'homes' },
  { src: '/images/gallery/coyol-sunset.jpg', title: 'Coyol Sunset', category: 'dining' },
  { src: '/images/gallery/coyol-night.jpg', title: 'Coyol at Night', category: 'dining' },
];
---

<Layout title="Gallery — Coyol Nosara">
  <Navigation />
  
  <!-- Hero -->
  <section class="relative h-[50vh] flex items-center justify-center bg-landrover-keswick">
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 to-black/30"></div>
    <div class="relative text-center z-10 px-6">
      <h1 class="text-5xl md:text-6xl font-serif text-white mb-4">Gallery</h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto">
        Life in Nosara — where jungle meets the sea
      </p>
    </div>
  </section>
  
  <!-- Filter Tabs -->
  <section class="bg-landrover-limestone py-6 sticky top-20 z-40">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-wrap gap-4 justify-center">
        <button class="filter-btn active px-6 py-2 rounded-full text-sm font-medium tracking-wider uppercase transition-all" data-filter="all">
          All
        </button>
        <button class="filter-btn px-6 py-2 rounded-full text-sm font-medium tracking-wider uppercase transition-all" data-filter="homes">
          Homes
        </button>
        <button class="filter-btn px-6 py-2 rounded-full text-sm font-medium tracking-wider uppercase transition-all" data-filter="activities">
          Activities
        </button>
        <button class="filter-btn px-6 py-2 rounded-full text-sm font-medium tracking-wider uppercase transition-all" data-filter="dining">
          Dining
        </button>
        <button class="filter-btn px-6 py-2 rounded-full text-sm font-medium tracking-wider uppercase transition-all" data-filter="lifestyle">
          Lifestyle
        </button>
      </div>
    </div>
  </section>
  
  <!-- Gallery Grid -->
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="gallery-grid">
        {images.map((img, i) => (
          <div 
            class="gallery-item group relative aspect-[4/3] overflow-hidden rounded-lg cursor-pointer"
            data-category={img.category}
            data-index={i}
          >
            <img 
              src={img.src} 
              alt={img.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <h3 class="text-white text-xl font-serif">{img.title}</h3>
                <p class="text-white/70 text-sm uppercase tracking-wider">{img.category}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 bg-black/95 z-50 hidden items-center justify-center">
    <button id="lightbox-close" class="absolute top-6 right-6 text-white text-4xl hover:text-white/70">&times;</button>
    <button id="lightbox-prev" class="absolute left-6 text-white text-4xl hover:text-white/70">&larr;</button>
    <button id="lightbox-next" class="absolute right-6 text-white text-4xl hover:text-white/70">&rarr;</button>
    <img id="lightbox-img" class="max-w-[90vw] max-h-[90vh] object-contain" />
    <div class="absolute bottom-6 left-0 right-0 text-center">
      <h3 id="lightbox-title" class="text-white text-xl font-serif"></h3>
    </div>
  </div>
  
  <Footer />
</Layout>

<style>
  .filter-btn {
    background: transparent;
    color: theme('colors.landrover.keswick');
    border: 1px solid theme('colors.landrover.keswick');
  }
  
  .filter-btn:hover, .filter-btn.active {
    background: theme('colors.landrover.keswick');
    color: white;
  }
  
  .gallery-item.hidden {
    display: none;
  }
</style>

<script>
  const images = [
    { src: '/images/gallery/IMG_3662.jpg', title: 'Tropical Living' },
    { src: '/images/gallery/DJI_20250326172154_0413_D.jpg', title: 'La Luna Beach' },
    { src: '/images/gallery/DJI_20250326172126_0411_D.jpg', title: 'La Luna Restaurant' },
    { src: '/images/gallery/IMG_1692.jpg', title: 'Horseback Riding' },
    { src: '/images/gallery/IMG_9939.jpg', title: 'Golden Hour Ride' },
    { src: '/images/gallery/IMG_1677.jpg', title: 'Tennis in the Jungle' },
    { src: '/images/gallery/DJI_20250326130411_0403_D.jpg', title: 'Mountain Views' },
    { src: '/images/gallery/IMG_0185.jpg', title: 'Modern Interiors' },
    { src: '/images/gallery/IMG_9739.jpg', title: 'Farm to Table' },
  ];
  
  let currentIndex = 0;
  
  // Filter functionality
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      const filter = btn.dataset.filter;
      document.querySelectorAll('.gallery-item').forEach(item => {
        if (filter === 'all' || item.dataset.category === filter) {
          item.classList.remove('hidden');
        } else {
          item.classList.add('hidden');
        }
      });
    });
  });
  
  // Lightbox
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxTitle = document.getElementById('lightbox-title');
  
  document.querySelectorAll('.gallery-item').forEach(item => {
    item.addEventListener('click', () => {
      currentIndex = parseInt(item.dataset.index || '0');
      showImage(currentIndex);
      lightbox?.classList.remove('hidden');
      lightbox?.classList.add('flex');
    });
  });
  
  function showImage(index: number) {
    if (lightboxImg) lightboxImg.src = images[index].src;
    if (lightboxTitle) lightboxTitle.textContent = images[index].title;
  }
  
  document.getElementById('lightbox-close')?.addEventListener('click', () => {
    lightbox?.classList.add('hidden');
    lightbox?.classList.remove('flex');
  });
  
  document.getElementById('lightbox-prev')?.addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + images.length) % images.length;
    showImage(currentIndex);
  });
  
  document.getElementById('lightbox-next')?.addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % images.length;
    showImage(currentIndex);
  });
  
  // Close on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      lightbox?.classList.add('hidden');
      lightbox?.classList.remove('flex');
    }
    if (e.key === 'ArrowLeft') {
      currentIndex = (currentIndex - 1 + images.length) % images.length;
      showImage(currentIndex);
    }
    if (e.key === 'ArrowRight') {
      currentIndex = (currentIndex + 1) % images.length;
      showImage(currentIndex);
    }
  });
</script>
