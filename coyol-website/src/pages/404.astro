---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | Coyol">
  <div class="min-h-screen flex items-center justify-center bg-landrover-limestone">
    <div class="text-center px-8">
      <h1 class="font-serif text-6xl text-landrover-keswick mb-4">404</h1>
      <p class="text-xl text-landrover-marine/70 mb-8">This page has moved or no longer exists.</p>
      <a 
        href="/" 
        class="inline-block bg-landrover-keswick text-white px-8 py-4 text-sm tracking-wider uppercase hover:bg-landrover-moss transition-colors"
      >
        Go to Homepage
      </a>
    </div>
  </div>
  <script>
    // Auto-redirect to homepage after 3 seconds
    setTimeout(() => {
      window.location.href = '/';
    }, 3000);
  </script>
</Layout>
