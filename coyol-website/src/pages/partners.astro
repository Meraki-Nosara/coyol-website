---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Partner Information | Coyol Real Estate">
  <main class="bg-landrover-limestone min-h-screen">
    
    <!-- Header -->
    <header class="bg-landrover-santorini text-white py-16 px-8">
      <div class="max-w-4xl mx-auto text-center">
        <img src="/images/logo.png" alt="Coyol" class="h-20 mx-auto mb-8 invert" />
        <h1 class="font-serif text-4xl md:text-5xl mb-4">Partner Information</h1>
        <p class="text-white/70 text-lg">Coyol Real Estate | Nosara, Costa Rica</p>
      </div>
    </header>

    <!-- About Nosara -->
    <section class="py-16 px-8 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-serif text-3xl text-landrover-santorini mb-6">About Nosara</h2>
        <div class="prose prose-lg text-landrover-santorini/80">
          <p>
            Nosara is located on Costa Rica's Nicoya Peninsula, one of only <strong>5 Blue Zones in the world</strong>, 
            where people regularly live to 100+. This isn't marketing; it's National Geographic-verified science.
          </p>
          <p>
            What makes Nosara special:
          </p>
          <ul>
            <li><strong>World-class surfing:</strong> Playa Guiones offers consistent breaks year-round</li>
            <li><strong>Wellness destination:</strong> Yoga, organic food, and holistic living are the norm</li>
            <li><strong>Protected nature:</strong> Strict development codes preserve the jungle canopy</li>
            <li><strong>Growing expat community:</strong> Americans, Canadians, Europeans seeking quality of life</li>
            <li><strong>Strong rental market:</strong> High-end vacation rentals command premium rates</li>
          </ul>
          <p>
            <strong>Climate:</strong> Tropical dry forest. 85°F (29°C) year-round. Dry season Dec-April, green season May-Nov.
          </p>
          <p>
            <strong>Access:</strong> 2.5 hours from Liberia International Airport (LIR) with direct flights from US/Canada. 
            Local airstrip (NOB) offers 30-minute flights from San José.
          </p>
        </div>
      </div>
    </section>

    <!-- The Family -->
    <section class="py-16 px-8 bg-landrover-limestone">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-serif text-3xl text-landrover-santorini mb-6">The Coyol Family</h2>
        <div class="prose prose-lg text-landrover-santorini/80">
          <p>
            The Coyol family has been part of Nosara for decades, building a reputation through hospitality before real estate. 
            Our restaurants, <strong>La Luna, Coyol, and Esh</strong>, are landmarks in the community, known for 
            exceptional food, design, and the feeling of being welcomed into someone's home.
          </p>
          <p>
            This same philosophy drives our real estate developments: <strong>thoughtful design, connection to nature, 
            and genuine care for the people who live here.</strong>
          </p>
        </div>
      </div>
    </section>

    <!-- Restaurants -->
    <section class="py-16 px-8 bg-white">
      <div class="max-w-5xl mx-auto">
        <h2 class="font-serif text-3xl text-landrover-santorini mb-10 text-center">Our Restaurants</h2>
        <div class="grid md:grid-cols-3 gap-8">
          
          <!-- La Luna -->
          <div class="bg-landrover-limestone rounded-lg overflow-hidden">
            <div class="aspect-[4/3] bg-[#A65D3F]/20 flex items-center justify-center">
              <img src="/images/laluna-restaurant-branded.png" alt="La Luna Restaurant" class="w-full h-full object-cover object-top" />
            </div>
            <div class="p-6">
              <h3 class="font-serif text-2xl text-landrover-santorini mb-2">La Luna</h3>
              <p class="text-landrover-santorini/70 text-sm mb-3">Playa Pelada</p>
              <p class="text-landrover-santorini/80">
                Beachfront dining under the stars. Mediterranean-inspired cuisine with 
                ocean views. The original, established over 20 years ago.
              </p>
            </div>
          </div>

          <!-- Coyol -->
          <div class="bg-landrover-limestone rounded-lg overflow-hidden">
            <div class="aspect-[4/3] bg-[#3D4F3D]/20 flex items-center justify-center">
              <img src="/images/coyol-restaurant-branded.png" alt="Coyol Restaurant" class="w-full h-full object-cover object-top" />
            </div>
            <div class="p-6">
              <h3 class="font-serif text-2xl text-landrover-santorini mb-2">Coyol</h3>
              <p class="text-landrover-santorini/70 text-sm mb-3">Las Flores</p>
              <p class="text-landrover-santorini/80">
                Farm-to-table Costa Rican fusion. Set in a jungle garden with 
                open-air seating. Where locals and visitors gather.
              </p>
            </div>
          </div>

          <!-- Esh -->
          <div class="bg-landrover-limestone rounded-lg overflow-hidden">
            <div class="aspect-[4/3] bg-[#C4A67C]/20 flex items-center justify-center">
              <img src="/images/esh-restaurant-branded.png" alt="Esh Restaurant" class="w-full h-full object-cover object-top" />
            </div>
            <div class="p-6">
              <h3 class="font-serif text-2xl text-landrover-santorini mb-2">Esh</h3>
              <p class="text-landrover-santorini/70 text-sm mb-3">Nosara</p>
              <p class="text-landrover-santorini/80">
                Israeli-Mediterranean street food. Fresh, vibrant, casual. 
                The newest addition to the family.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Developments -->
    <section class="py-16 px-8 bg-landrover-santorini text-white">
      <div class="max-w-5xl mx-auto">
        <h2 class="font-serif text-3xl mb-10 text-center">Real Estate Developments</h2>
        
        <!-- Mar Azul -->
        <div class="mb-16">
          <h3 class="font-serif text-2xl mb-4 text-landrover-sand">Mar Azul</h3>
          <div class="grid md:grid-cols-2 gap-8 items-start">
            <div>
              <p class="text-white/80 mb-4">
                Our flagship development. 40 homesites high in the hills with 
                <strong>panoramic ocean and jungle views</strong>. The highest and most private of our developments, 
                a short drive to beaches, restaurants, and yoga studios.
              </p>
              <ul class="text-white/70 space-y-2 mb-6">
                <li>• Lot sizes: 1,500 - 4,000 m² (0.4 - 1 acre)</li>
                <li>• <strong>Lots:</strong> $180,000 - $2,000,000 USD</li>
                <li>• <strong>Homes:</strong> $1M - $7M USD (depending on lot + design)</li>
                <li>• Underground utilities, paved roads</li>
                <li>• Architectural guidelines to protect views</li>
                <li>• Build-ready with water letters</li>
              </ul>
            </div>
            <div class="space-y-4">
              <img src="/images/render-glass-jungle.jpg" alt="Mar Azul render" class="w-full rounded-lg" />
              <img src="/images/render-mountain-view.jpg" alt="Mar Azul view" class="w-full rounded-lg" />
            </div>
          </div>
        </div>

        <!-- Nosara Hills -->
        <div class="mb-16">
          <h3 class="font-serif text-2xl mb-4 text-landrover-sand">Nosara Hills</h3>
          <div class="grid md:grid-cols-2 gap-8 items-start">
            <div>
              <p class="text-white/80 mb-4">
                Established community with a mix of completed homes and available lots. 
                Known for stunning <strong>sunset views over the Pacific</strong>.
              </p>
              <ul class="text-white/70 space-y-2 mb-6">
                <li>• Lot sizes: 2,000 - 6,000 m²</li>
                <li>• <strong>Lots:</strong> $150,000 - $600,000 USD</li>
                <li>• <strong>Homes:</strong> $1M - $7M USD</li>
                <li>• Existing homes available</li>
                <li>• Mature landscaping, established roads</li>
              </ul>
            </div>
            <div class="space-y-4">
              <img src="/images/render-hacienda.jpg" alt="Nosara Hills style" class="w-full rounded-lg" />
            </div>
          </div>
        </div>

        <!-- Los Coyoles -->
        <div>
          <h3 class="font-serif text-2xl mb-4 text-landrover-sand">Los Coyoles</h3>
          <p class="text-white/80">
            <strong>Coming soon.</strong> Our newest development, currently in planning. 
            Contact us for early access and details.
          </p>
        </div>

      </div>
    </section>

    <!-- Renders Gallery -->
    <section class="py-16 px-8 bg-white">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-serif text-3xl text-landrover-santorini mb-10 text-center">Architectural Vision</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          <img src="/images/render-glass-jungle.jpg" alt="Modern jungle home" class="w-full rounded-lg" />
          <img src="/images/render-mountain-view.jpg" alt="Mountain view home" class="w-full rounded-lg" />
          <img src="/images/render-hacienda.jpg" alt="Hacienda style" class="w-full rounded-lg" />
          <img src="/images/render-interior-greatroom.jpg" alt="Great room interior" class="w-full rounded-lg" />
          <img src="/images/render-master-suite.jpg" alt="Master suite" class="w-full rounded-lg" />
          <img src="/images/render-kitchen.jpg" alt="Modern kitchen" class="w-full rounded-lg" />
        </div>
        <p class="text-center text-landrover-santorini/60 mt-6 text-sm">
          Architectural renders showing the design vision. Custom homes designed to your specifications.
        </p>
      </div>
    </section>

    <!-- Working With Us -->
    <section class="py-16 px-8 bg-landrover-limestone">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-serif text-3xl text-landrover-santorini mb-6">Working With Partner Agents</h2>
        <div class="prose prose-lg text-landrover-santorini/80">
          <p>
            We welcome partnerships with qualified real estate professionals who can represent our 
            developments to international buyers. Our typical arrangement:
          </p>
          <ul>
            <li><strong>Referral commission:</strong> Competitive rates for qualified buyer introductions</li>
            <li><strong>Marketing support:</strong> High-resolution images, videos, and property details</li>
            <li><strong>Site visits:</strong> We host agent familiarization trips</li>
            <li><strong>Transaction support:</strong> Our local team handles Costa Rica legal/closing</li>
          </ul>
          <p>
            We're selective about partnerships. We want agents who understand our vision and will 
            represent the properties with the same care we put into creating them.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="py-16 px-8 bg-landrover-santorini text-white">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-serif text-3xl mb-6">Let's Talk</h2>
        <p class="text-white/80 mb-8">
          Interested in representing Coyol Real Estate developments?
        </p>
        <div class="space-y-2 text-lg">
          <p><strong>Marion Peri</strong></p>
          <p>marionnosara@gmail.com</p>
          <p class="mt-4">
            <a href="https://wa.me/18184018068" target="_blank" class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#20bd5a] text-white px-6 py-3 rounded-full transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          </p>
          <p class="text-white/60 text-sm">Nosara, Costa Rica</p>
        </div>
        <div class="mt-10 pt-10 border-t border-white/20">
          <a href="/" class="text-landrover-sand hover:text-white transition-colors">
            ← Visit coyolrealestate.com
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  .prose ul {
    list-style-type: disc;
    padding-left: 1.5rem;
  }
  .prose li {
    margin-bottom: 0.5rem;
  }
</style>
