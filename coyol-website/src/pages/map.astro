  { id: 2, name: 'Ocean Vista 3', lat: 10.0085, lng: -85.6305, area: '3,580 m²', status: 'available', view: 'Pacific Ocean', image: '/images/renders/render-mountain-view.jpg' },
  { id: 3, name: 'Jungle Canopy 7', lat: 10.0075, lng: -85.6315, area: '4,200 m²', status: 'reserved', view: 'Forest Reserve', image: '/images/renders/render-pool-deck.jpg' },
  { id: 4, name: 'Sunset Ridge 12', lat: 10.0070, lng: -85.6308, area: '2,920 m²', status: 'available', view: 'Sunset Views', image: '/images/renders/render-living-room.jpg' },
  { id: 5, name: 'Waterfall Estate', lat: 10.0060, lng: -85.6320, area: '3,850 m²', status: 'sold', view: 'Waterfall & Lagoon', image: '/images/renders/render-glass-jungle.jpg' },
