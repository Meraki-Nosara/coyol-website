    { id: 8, x: 355, y: 230, w: 28, h: 22, area: 3250, status: 'available', view: 'Road Front' },
    { id: 9, x: 390, y: 225, w: 26, h: 20, area: 2890, status: 'available', view: 'Central Location' },
    { id: 10, x: 425, y: 220, w: 28, h: 22, area: 3100, status: 'available', view: 'Jungle & Ocean' },
    { id: 11, x: 460, y: 215, w: 26, h: 20, area: 2650, status: 'reserved', view: 'Garden Views' },
    { id: 12, x: 495, y: 218, w: 28, h: 22, area: 3000, status: 'available', view: 'Trail Access' },
    { id: 13, x: 530, y: 225, w: 26, h: 20, area: 2780, status: 'available', view: 'Nature Path' },
    { id: 14, x: 565, y: 235, w: 28, h: 22, area: 3600, status: 'available', view: 'East Views' },
    
    // Middle section - inner curve of the S-road
    { id: 15, x: 370, y: 275, w: 28, h: 22, area: 3150, status: 'available', view: 'Inner Circle' },
    { id: 16, x: 410, y: 268, w: 26, h: 20, area: 3400, status: 'available', view: 'Park Adjacent' },
    { id: 17, x: 450, y: 262, w: 28, h: 22, area: 2950, status: 'available', view: 'Central Hub' },
    { id: 18, x: 490, y: 265, w: 26, h: 20, area: 3100, status: 'available', view: 'Trail Junction' },
    { id: 19, x: 530, y: 272, w: 28, h: 22, area: 2700, status: 'available', view: 'Forest Edge' },
    { id: 20, x: 570, y: 282, w: 26, h: 20, area: 2480, status: 'available', view: 'East Ridge' },
    
    // Lower curve section
    { id: 21, x: 395, y: 320, w: 28, h: 22, area: 3050, status: 'reserved', view: 'Valley Views' },
    { id: 22, x: 435, y: 315, w: 26, h: 20, area: 2820, status: 'available', view: 'Jungle Canopy' },
    { id: 23, x: 475, y: 312, w: 28, h: 22, area: 3380, status: 'available', view: 'Private Setting' },
    { id: 24, x: 515, y: 318, w: 26, h: 20, area: 2550, status: 'available', view: 'Nature Reserve' },
    { id: 25, x: 555, y: 328, w: 28, h: 22, area: 4200, status: 'available', view: 'Premium Lot' },
    { id: 26, x: 595, y: 340, w: 26, h: 20, area: 3650, status: 'available', view: 'East Forest' },
    
    // Lower section - toward East Gate
    { id: 27, x: 440, y: 365, w: 28, h: 22, area: 3850, status: 'available', view: 'South Facing' },
    { id: 28, x: 485, y: 360, w: 26, h: 20, area: 3200, status: 'available', view: 'Playground Area' },
    { id: 29, x: 530, y: 368, w: 30, h: 24, area: 4500, status: 'available', view: 'Family Lot' },
    { id: 30, x: 575, y: 380, w: 28, h: 22, area: 4100, status: 'available', view: 'Trail End' },
    
    // East Gate approach
    { id: 31, x: 505, y: 415, w: 26, h: 20, area: 3400, status: 'available', view: 'Gate Adjacent' },
    { id: 32, x: 550, y: 425, w: 28, h: 22, area: 3100, status: 'available', view: 'Easy Access' },
    { id: 33, x: 595, y: 440, w: 26, h: 20, area: 2900, status: 'available', view: 'Entry Views' },
    
    // Southeast lots near East Gate
    { id: 34, x: 555, y: 475, w: 28, h: 22, area: 3750, status: 'available', view: 'Corner Lot' },
    { id: 35, x: 600, y: 490, w: 26, h: 20, area: 3450, status: 'available', view: 'East Gate' },
    { id: 36, x: 640, y: 460, w: 26, h: 20, area: 3200, status: 'available', view: 'Private Entry' },
  ];
  
  // DOM elements
  const aerialImage = document.getElementById('aerial-image') as HTMLImageElement;
  const lotOverlay = document.getElementById('lot-overlay') as SVGSVGElement;
  const loading = document.getElementById('loading')!;
  const lotPanel = document.getElementById('lot-panel')!;
  const closeLotPanel = document.getElementById('close-lot-panel')!;
  const mapControls = document.getElementById('map-controls')!;
  const legend = document.getElementById('legend')!;
  const mapHint = document.getElementById('map-hint')!;
  
  // Map state
  let scale = 1;
  let translateX = -25; // Center offset
  let translateY = -25;
  let isDragging = false;
  let startX = 0;
  let startY = 0;
  let selectedLotId: number | null = null;
  
  // Render lots on SVG
  function renderLots() {
    lotOverlay.innerHTML = '';
    
    lots.forEach(lot => {
      // Create lot polygon (rounded rectangle approximation)
      const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
      rect.setAttribute('x', String(lot.x));
      rect.setAttribute('y', String(lot.y));
      rect.setAttribute('width', String(lot.w));
      rect.setAttribute('height', String(lot.h));
      rect.setAttribute('rx', '4');
      rect.setAttribute('ry', '4');
      rect.setAttribute('class', `lot ${lot.status}${selectedLotId === lot.id ? ' selected' : ''}`);
      rect.setAttribute('data-id', String(lot.id));
      
      // Click handler
      rect.addEventListener('click', () => selectLot(lot.id));
      
      lotOverlay.appendChild(rect);
      
      // Add lot number label
      const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      label.setAttribute('x', String(lot.x + lot.w / 2));
      label.setAttribute('y', String(lot.y + lot.h / 2));
      label.setAttribute('class', 'lot-label');
      label.textContent = String(lot.id);
      lotOverlay.appendChild(label);
    });
  }
  
  // Select lot
  function selectLot(id: number) {
    const lot = lots.find(l => l.id === id);
    if (!lot) return;
    
    selectedLotId = id;
    renderLots();
    
    // Update panel
    document.getElementById('lot-number')!.textContent = `Lot ${lot.id}`;
    document.getElementById('lot-area')!.textContent = `${lot.area.toLocaleString()} m²`;
    
    const statusEl = document.getElementById('lot-status')!;
    statusEl.textContent = lot.status.charAt(0).toUpperCase() + lot.status.slice(1);
    statusEl.className = `status-${lot.status}`;
    
    document.getElementById('lot-view')!.textContent = lot.view;
    document.getElementById('lot-elevation')!.textContent = `${320 + Math.floor(lot.id * 2)}m`;
    
    lotPanel.classList.remove('hidden');
    mapControls.classList.add('shifted');
    legend.classList.add('shifted');
  }
  
  // Close panel
  closeLotPanel.addEventListener('click', () => {
    lotPanel.classList.add('hidden');
    mapControls.classList.remove('shifted');
    legend.classList.remove('shifted');
    selectedLotId = null;
    renderLots();
  });
  
  // Update transform
  function updateTransform() {
    const transform = `translate(${translateX}%, ${translateY}%) scale(${scale})`;
    aerialImage.style.transform = transform;
    lotOverlay.style.transform = transform;
  }
  
  // Pan handlers
  aerialImage.addEventListener('mousedown', (e) => {
    isDragging = true;
    startX = e.clientX;
    startY = e.clientY;
    aerialImage.style.cursor = 'grabbing';
  });
  
  document.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    
    const dx = (e.clientX - startX) / window.innerWidth * 100 / scale;
    const dy = (e.clientY - startY) / window.innerHeight * 100 / scale;
    
    translateX += dx;
    translateY += dy;
    
    // Clamp
    translateX = Math.max(-50, Math.min(0, translateX));
    translateY = Math.max(-50, Math.min(0, translateY));
    
    startX = e.clientX;
    startY = e.clientY;
    
    updateTransform();
  });
  
  document.addEventListener('mouseup', () => {
    isDragging = false;
    aerialImage.style.cursor = 'grab';
  });
  
  // Zoom handlers
  document.getElementById('zoom-in')!.addEventListener('click', () => {
    scale = Math.min(3, scale * 1.3);
    updateTransform();
  });
  
  document.getElementById('zoom-out')!.addEventListener('click', () => {
    scale = Math.max(0.8, scale / 1.3);
    updateTransform();
  });
  
  document.getElementById('reset-view')!.addEventListener('click', () => {
    scale = 1;
    translateX = -25;
    translateY = -25;
    updateTransform();
  });
  
  // Mouse wheel zoom
  document.addEventListener('wheel', (e) => {
    if (e.deltaY < 0) {
      scale = Math.min(3, scale * 1.1);
    } else {
      scale = Math.max(0.8, scale / 1.1);
    }
    updateTransform();
  }, { passive: true });
  
  // Update stats
  const statAvailable = document.getElementById('stat-available')!;
  const statReserved = document.getElementById('stat-reserved')!;
  const statSold = document.getElementById('stat-sold')!;
  
  let counts = { available: 0, reserved: 0, sold: 0 };
  lots.forEach(lot => {
    counts[lot.status as keyof typeof counts]++;
  });
  statAvailable.textContent = String(counts.available);
  statReserved.textContent = String(counts.reserved);
  statSold.textContent = String(counts.sold);
  
  // Initialize
  renderLots();
  updateTransform();
  
  // Hide loading after image loads
  aerialImage.onload = () => {
    setTimeout(() => loading.classList.add('hidden'), 500);
  };
  
  // Fallback if image already cached
  if (aerialImage.complete) {
    setTimeout(() => loading.classList.add('hidden'), 500);
  }
  
  // Hide hint after interaction
  let hintHidden = false;
  document.addEventListener('mousedown', () => {
    if (!hintHidden) {
      mapHint.style.opacity = '0';
      hintHidden = true;
    }
  });
</script>
