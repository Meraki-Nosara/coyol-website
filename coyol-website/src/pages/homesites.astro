---
import Layout from '../layouts/Layout.astro';

// Homes for sale - actual properties with renders/photos
const homesites = [
  {
    id: 'casa-nest',
    name: 'Casa Nest',
    area: 'Lot 28',
    acres: 'Mar Azul',
    description: 'A dramatic cantilevered design with infinity pool, fire pit deck, and panoramic jungle views. Bold modern architecture that floats above the landscape.',
    features: ['Cantilevered Design', 'Infinity Pool', 'Ocean Views'],
    image: '/images/properties/casa-nest.jpg',
    status: 'Design'
  },
  {
    id: 'casa-lefki',
    name: 'Casa Lefki',
    area: 'Lot 25',
    acres: 'Mar Azul',
    description: 'Modern glass pavilion nestled among mature Guanacaste trees. Floor-to-ceiling windows frame the jungle canopy and distant ocean.',
    features: ['Modern Glass', 'Guanacaste Trees', 'Pool Terrace'],
    image: '/images/properties/casa-lefki.jpg',
    status: 'Design'
  },
  {
    id: 'casa-umi',
    name: 'Casa Umi',
    area: 'Lot 34',
    acres: 'Mar Azul',
    description: 'Contemporary design featuring black charred wood cladding and gabion stone walls. A bold statement in harmony with the forest.',
    features: ['Black Wood', 'Gabion Walls', 'Forest Setting'],
    image: '/images/properties/casa-umi.jpg',
    status: 'Design'
  },
  {
    id: 'casa-cacao',
    name: 'Casa Cacao',
    area: 'Lot 21',
    acres: 'Mar Azul',
    description: 'Stone and charred wood combine in this modern farmhouse design. Sweeping mountain views from every room.',
    features: ['Stone & Wood', 'Mountain Views', 'Modern Farmhouse'],
    image: '/images/properties/casa-cacao.jpg',
    status: 'Design'
  },
  {
    id: 'casa-luz',
    name: 'Casa Luz',
    area: 'Lot 21',
    acres: 'Mar Azul',
    description: 'A compound of connected pavilions with stone details and jungle courtyards. Indoor-outdoor living at its finest.',
    features: ['Pavilion Style', 'Stone Details', 'Jungle Compound'],
    image: '/images/properties/casa-luz.jpg',
    status: 'Design'
  },
  {
    id: 'casa-elle',
    name: 'Casa Elle',
    area: 'Lot 14',
    acres: 'Mar Azul',
    description: 'Classic hacienda architecture with clay tile roof and covered terraces. A completed masterpiece ready for its next chapter.',
    features: ['Hacienda Style', 'Clay Tile Roof', 'Completed'],
    image: '/images/properties/casa-elle.jpg',
    floorplan: '/images/floorplans/casa-elle-floorplan.jpg',
    status: 'Completed'
  },
];
---

<Layout title="Available Homesites | Mar Azul | Coyol Real Estate">
  <!-- Hero with aerial -->
  <section class="hero">
    <div class="hero-image">
      <img src="/images/homesite-construction.jpg" alt="Homesite under construction in Mar Azul" />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <span class="overline">Mar Azul</span>
      <h1>Available Homesites</h1>
      <p>36 jungle homesites on a pristine ridgeline, minutes from Playa Guiones</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="intro">
    <div class="container">
      <p class="lead">
        Mar Azul's homesites are positioned to maximize privacy, natural beauty, 
        and the spectacular views that make this ridgeline one of Nosara's most 
        coveted locations.
      </p>
    </div>
  </section>

  <!-- Homesites grid -->
  <section class="homesites">
    <div class="container">
      <div class="grid">
        {homesites.map((site) => (
          <div class={`homesite-card ${site.floorplan ? 'has-floorplan' : ''}`}>
            <div class="card-inner">
              <div class="card-front">
                <div class="card-image">
                  <img src={site.image} alt={site.name} />
                  {site.floorplan && <span class="flip-hint">Tap for floor plan</span>}
                </div>
                <div class="card-content">
                  <h3>{site.name}</h3>
                  <p class="specs">{site.area} · {site.acres}</p>
                  <ul class="features">
                    {site.features.map((f) => (
                      <li>{f}</li>
                    ))}
                  </ul>
                  <a href={`/homesites/${site.id}`} class="view-details" onclick="event.stopPropagation()">More Info</a>
                </div>
              </div>
              {site.floorplan && (
                <div class="card-back">
                  <div class="card-image">
                    <img src={site.floorplan} alt={`${site.name} Floor Plan`} />
                    <span class="flip-hint">Tap to go back</span>
                  </div>
                  <div class="card-content">
                    <h3>{site.name}: Floor Plan</h3>
                    <a href={`/homesites/${site.id}`} class="view-details" onclick="event.stopPropagation()">More Info</a>
                  </div>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Find Your Homesite</h2>
        <p>Schedule a private tour to explore Mar Azul and discover the perfect setting for your Costa Rica home.</p>
        <a href="/#contact" class="cta-button">Schedule a Tour</a>
      </div>
      <div class="cta-image">
        <img src="/images/lot-markers.jpg" alt="Mar Azul lot markers" />
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    height: 80vh;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      180deg,
      rgba(26, 31, 22, 0.3) 0%,
      rgba(26, 31, 22, 0.6) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    color: #F5F3EF;
    padding: 0 24px;
  }

  .overline {
    display: block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #C4A67C;
    margin-bottom: 16px;
  }

  .hero-content h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 400;
    margin: 0 0 16px 0;
    line-height: 1.1;
  }

  .hero-content p {
    font-size: 18px;
    opacity: 0.9;
    max-width: 500px;
    margin: 0 auto;
  }

  /* Intro */
  .intro {
    padding: 80px 24px;
    background: #F5F3EF;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .lead {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(20px, 3vw, 28px);
    line-height: 1.6;
    color: #1A1F16;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  /* Homesites grid */
  .homesites {
    padding: 80px 24px;
    background: #fff;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 32px;
  }

  .homesite-card {
    display: block;
    text-decoration: none;
    background: #F5F3EF;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
    perspective: 1000px;
  }

  .homesite-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
  }

  /* Flip card styles */
  .homesite-card.has-floorplan {
    cursor: pointer;
  }

  .homesite-card .card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.6s;
    transform-style: preserve-3d;
  }

  .homesite-card.has-floorplan.flipped .card-inner {
    transform: rotateY(180deg);
  }

  .homesite-card .card-front,
  .homesite-card .card-back {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .homesite-card .card-back {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transform: rotateY(180deg);
    background: #1A1F16;
  }

  .homesite-card .card-back .card-content {
    background: #1A1F16;
  }

  .homesite-card .card-back .card-content h3 {
    color: #F5F3EF;
  }

  .flip-hint {
    position: absolute;
    bottom: 12px;
    right: 12px;
    background: rgba(0,0,0,0.6);
    color: #fff;
    font-size: 11px;
    padding: 6px 12px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .view-details {
    display: inline-block;
    margin-top: 16px;
    padding: 10px 20px;
    background: #3D4F3D;
    color: #F5F3EF;
    font-size: 12px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.3s;
  }

  .view-details:hover {
    background: #4A5D4A;
  }

  .card-image {
    aspect-ratio: 4/3;
    overflow: hidden;
    position: relative;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }

  /* Floor plan should show full image, not cropped */
  .card-back .card-image {
    aspect-ratio: auto;
    background: #1A1F16;
    padding: 16px;
  }

  .card-back .card-image img {
    object-fit: contain;
    max-height: 400px;
  }

  .homesite-card:hover .card-front .card-image img {
    transform: scale(1.05);
  }

  .card-content {
    padding: 24px;
  }

  .card-content h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 24px;
    font-weight: 400;
    color: #1A1F16;
    margin: 0 0 8px 0;
  }

  .specs {
    font-size: 14px;
    color: #3D4F3D;
    margin: 0 0 16px 0;
    font-weight: 500;
  }

  .features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .features li {
    font-size: 12px;
    color: #666;
    padding: 4px 12px;
    background: rgba(61, 79, 61, 0.1);
    border-radius: 20px;
  }

  /* CTA Section */
  .cta-section {
    background: #1A1F16;
  }

  .cta-section .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 500px;
  }

  .cta-content {
    padding: 80px 60px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .cta-content h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 40px;
    font-weight: 400;
    color: #F5F3EF;
    margin: 0 0 16px 0;
  }

  .cta-content p {
    font-size: 16px;
    color: rgba(212, 201, 181, 0.8);
    line-height: 1.7;
    margin: 0 0 32px 0;
  }

  .cta-button {
    display: inline-block;
    padding: 16px 32px;
    background: #3D4F3D;
    color: #F5F3EF;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.3s;
    align-self: flex-start;
  }

  .cta-button:hover {
    background: #4A5D4A;
  }

  .cta-image {
    overflow: hidden;
  }

  .cta-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Mobile */
  @media (max-width: 900px) {
    .cta-section .container {
      grid-template-columns: 1fr;
    }

    .cta-content {
      padding: 60px 24px;
    }

    .cta-image {
      height: 300px;
    }
  }

  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Flip card interaction for cards with floor plans
  document.querySelectorAll('.homesite-card.has-floorplan').forEach(card => {
    card.addEventListener('click', (e) => {
      // Don't flip if clicking on the "View Details" link
      if ((e.target as HTMLElement).closest('.view-details')) return;
      card.classList.toggle('flipped');
    });
  });
</script>
