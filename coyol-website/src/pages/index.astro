---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import ParallaxSection from '../components/ParallaxSection.astro';
import FamilyBrands from '../components/FamilyBrands.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Coyol | A Way of Life in Nosara">
  <Navigation />
  
  <main>
    <!-- Hero Section - Lifestyle First -->
    <section id="home" class="relative h-screen overflow-hidden">
      <video 
        autoplay 
        muted 
        loop 
        playsinline
        class="absolute inset-0 w-full h-full object-cover"
        poster="/images/render-glass-jungle.jpg"
      >
        <source src="/videos/nosara-lifestyle.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-b from-landrover-santorini/30 via-transparent to-landrover-santorini/60"></div>
      
      <div class="relative z-10 h-full flex flex-col items-center justify-center text-center px-8">
        <p class="scroll-fade text-white/70 text-xs tracking-[0.4em] uppercase mb-6" data-delay="0">
          Nosara, Costa Rica
        </p>
        <h1 class="scroll-fade font-serif text-4xl md:text-5xl lg:text-6xl xl:text-7xl text-white max-w-4xl leading-tight" data-delay="100">
          A way of life, rooted in generosity
        </h1>
        <a 
          href="#story" 
          class="scroll-fade mt-16 opacity-0"
          data-delay="400"
        >
          <div class="w-8 h-14 border-2 border-white/40 rounded-full flex items-start justify-center p-2">
            <div class="w-1.5 h-3 bg-white/60 rounded-full animate-bounce"></div>
          </div>
        </a>
      </div>
    </section>

    <!-- The Story - Your Site's Copy -->
    <section id="story" class="py-32 lg:py-48 bg-landrover-limestone">
      <div class="max-w-4xl mx-auto px-8">
        <p class="scroll-fade font-serif text-2xl md:text-3xl lg:text-4xl text-landrover-santorini leading-relaxed text-center" data-delay="0">
          This is a place curated by a family, shaped by decades of hosting, feeding, 
          and caring for people in Nosara through La Luna, Coyol, and Esh.
        </p>
      </div>
    </section>

    <!-- Continuation of Legacy -->
    <ParallaxSection
      image="/images/render-glass-jungle.jpg"
      subtitle=""
      title=""
    >
      <div class="max-w-3xl text-center">
        <p class="scroll-fade font-serif text-xl md:text-2xl lg:text-3xl text-white/90 leading-relaxed" data-delay="100">
          Created and imagined by the same hands and minds, these homesites grow from 
          a way of life rooted in generosity, connection, and time.
        </p>
      </div>
    </ParallaxSection>

    <!-- What Once Gathered -->
    <section class="py-32 lg:py-48 bg-landrover-pangea">
      <div class="max-w-5xl mx-auto px-8 text-center">
        <p class="scroll-fade font-serif text-2xl md:text-3xl lg:text-4xl text-landrover-santorini leading-relaxed" data-delay="0">
          What once gathered people around tables now gathers them around homes—designed 
          with the same intention and care.
        </p>
      </div>
    </section>

    <!-- Family Brands - The Legacy -->
    <FamilyBrands />

    <!-- Blue Zone Section -->
    <section class="py-32 lg:py-48 bg-landrover-keswick text-white">
      <div class="max-w-7xl mx-auto px-8">
        <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
          <div class="scroll-fade" data-delay="0">
            <div class="aspect-[4/5] overflow-hidden">
              <img 
                src="/images/render-hacienda.jpg"
                alt="Life in Nosara"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
          <div>
            <p class="scroll-fade text-landrover-limestone/60 text-xs tracking-[0.3em] uppercase mb-6" data-delay="0">Nicoya Peninsula</p>
            <h2 class="scroll-fade font-serif text-3xl md:text-4xl lg:text-5xl mb-8 leading-tight" data-delay="100">
              Set within Nicoya's Blue Zone, between forest and ocean
            </h2>
            <p class="scroll-fade text-landrover-limestone/70 text-lg lg:text-xl leading-relaxed mb-8" data-delay="200">
              Each place is designed with the same hands and minds that have long understood 
              what it means to make people feel welcome.
            </p>
            <p class="scroll-fade text-landrover-limestone/70 text-lg lg:text-xl leading-relaxed" data-delay="300">
              The Nicoya Peninsula is one of only five Blue Zones on Earth—regions where 
              people live measurably longer, healthier lives.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- More Than Real Estate -->
    <section class="py-32 lg:py-48 bg-landrover-limestone">
      <div class="max-w-4xl mx-auto px-8 text-center">
        <p class="scroll-fade font-serif text-2xl md:text-3xl lg:text-4xl xl:text-5xl text-landrover-santorini leading-relaxed" data-delay="0">
          More than real estate, this is a continuation of a legacy—quietly crafted, 
          deeply human, and meant to be lived.
        </p>
      </div>
    </section>

    <!-- Living Here Parallax -->
    <ParallaxSection
      image="/images/mar-azul-lot34-render.jpg"
      subtitle="The Life"
      title="Surf before breakfast. Dine under stars."
      description="Wake to howler monkeys. Watch the sunset from your terrace. This is home."
      align="center"
    />

    <!-- Explore Section - Subtle Real Estate -->
    <section id="explore" class="py-32 lg:py-48 bg-landrover-alaska">
      <div class="max-w-7xl mx-auto px-8">
        <div class="text-center mb-20">
          <p class="scroll-fade text-landrover-coniston text-xs tracking-[0.3em] uppercase mb-4" data-delay="0">Explore</p>
          <h2 class="scroll-fade font-serif text-4xl md:text-5xl lg:text-6xl text-landrover-santorini mb-6" data-delay="100">
            Find Your Place
          </h2>
          <p class="scroll-fade text-landrover-marine/70 text-lg max-w-2xl mx-auto" data-delay="200">
            Three distinct communities, each with its own character. Discover the one that feels like home.
          </p>
        </div>
        
        <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
          <!-- Nosara Hills -->
          <article class="scroll-fade group relative overflow-hidden" data-delay="0">
            <div class="aspect-[3/4] overflow-hidden">
              <img 
                src="/images/render-mountain-view.jpg"
                alt="Nosara Hills"
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
              />
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-landrover-santorini/90 via-landrover-santorini/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-8">
              <h3 class="font-serif text-3xl lg:text-4xl text-white mb-3">Nosara Hills</h3>
              <p class="text-landrover-limestone/70 text-sm lg:text-base">Elevated views, morning mist, evening breeze</p>
            </div>
          </article>
          
          <!-- Mar Azul -->
          <article class="scroll-fade group relative overflow-hidden" data-delay="150">
            <div class="aspect-[3/4] overflow-hidden">
              <img 
                src="/images/mar-azul-lot34-render.jpg"
                alt="Mar Azul"
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
              />
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-landrover-santorini/90 via-landrover-santorini/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-8">
              <h3 class="font-serif text-3xl lg:text-4xl text-white mb-3">Mar Azul</h3>
              <p class="text-landrover-limestone/70 text-sm lg:text-base">Steps from the ocean, immersed in nature</p>
            </div>
          </article>
          
          <!-- Los Coyoles -->
          <article class="scroll-fade group relative overflow-hidden" data-delay="300">
            <div class="aspect-[3/4] overflow-hidden">
              <img 
                src="/images/render-hacienda.jpg"
                alt="Los Coyoles"
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
              />
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-landrover-santorini/90 via-landrover-santorini/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-8">
              <h3 class="font-serif text-3xl lg:text-4xl text-white mb-3">Los Coyoles</h3>
              <p class="text-landrover-limestone/70 text-sm lg:text-base">Secluded among ancient trees</p>
            </div>
          </article>
        </div>
        
        <div class="scroll-fade text-center mt-16" data-delay="200">
          <a 
            href="/map-cesium" 
            class="inline-block border border-landrover-keswick text-landrover-keswick px-12 py-5 text-xs font-medium tracking-[0.2em] uppercase hover:bg-landrover-keswick hover:text-white transition-colors"
          >
            Explore the Land
          </a>
        </div>
      </div>
    </section>

    <!-- Interior Living -->
    <section class="py-32 lg:py-48 bg-landrover-pangea">
      <div class="max-w-7xl mx-auto px-8">
        <div class="grid lg:grid-cols-2 gap-8">
          <div class="scroll-fade" data-delay="0">
            <div class="aspect-square overflow-hidden">
              <img 
                src="/images/render-interior-greatroom.jpg"
                alt="Living spaces"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
          <div class="scroll-fade" data-delay="150">
            <div class="aspect-square overflow-hidden">
              <img 
                src="/images/render-interior-bedroom.jpg"
                alt="Bedroom"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
        <div class="grid lg:grid-cols-3 gap-8 mt-8">
          <div class="scroll-fade" data-delay="200">
            <div class="aspect-[4/3] overflow-hidden">
              <img 
                src="/images/render-kitchen.jpg"
                alt="Kitchen"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
          <div class="scroll-fade lg:col-span-2" data-delay="250">
            <div class="aspect-[2/1] overflow-hidden">
              <img 
                src="/images/render-master-suite.jpg"
                alt="Master suite"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Final Statement -->
    <ParallaxSection
      image="/images/render-mountain-view.jpg"
      subtitle=""
      title=""
    >
      <div class="max-w-4xl text-center">
        <p class="scroll-fade font-serif text-3xl md:text-4xl lg:text-5xl text-white leading-tight" data-delay="100">
          Quietly crafted. Deeply human. Meant to be lived.
        </p>
        <a 
          href="#contact" 
          class="scroll-fade inline-block mt-12 bg-white/10 backdrop-blur border border-white/30 text-white px-12 py-5 text-xs font-medium tracking-[0.2em] uppercase hover:bg-white hover:text-landrover-keswick transition-colors"
          data-delay="300"
        >
          Begin the Conversation
        </a>
      </div>
    </ParallaxSection>

    <!-- Contact -->
    <Contact />
  </main>
  
  <Footer />
</Layout>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  
  ::-webkit-scrollbar {
    width: 6px;
  }
  
  ::-webkit-scrollbar-track {
    background: #E8E2D6;
  }
  
  ::-webkit-scrollbar-thumb {
    background: #4A5D4A;
  }
  
  ::-webkit-scrollbar-thumb:hover {
    background: #3D4F3D;
  }
  
  .img-zoom img {
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .img-zoom:hover img {
    transform: scale(1.08);
  }
  
  .scroll-fade {
    opacity: 0;
    transform: translateY(60px);
  }
  
  .scroll-fade.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const allScrollFade = document.querySelectorAll('.scroll-fade:not(.parallax-section .scroll-fade)');
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const delay = parseInt(el.dataset.delay || '0');
        
        setTimeout(() => {
          el.style.transition = 'opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1)';
          el.classList.add('visible');
        }, delay);
        
        observer.unobserve(el);
      }
    });
  }, {
    threshold: 0.1,
    rootMargin: '0px 0px -5% 0px'
  });
  
  allScrollFade.forEach(el => observer.observe(el));
</script>
