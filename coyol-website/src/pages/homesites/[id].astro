---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { id: 'casa-nest' } },
    { params: { id: 'casa-lefki' } },
    { params: { id: 'casa-umi' } },
    { params: { id: 'casa-cacao' } },
    { params: { id: 'casa-luz' } },
  ];
}

const { id } = Astro.params;

const properties: Record<string, any> = {
  'casa-nest': {
    name: 'Casa Nest',
    tagline: 'A dramatic cantilevered design floating above the landscape',
    location: 'Lot 28, Mar Azul',
    status: 'Design',
    image: '/images/properties/casa-nest.jpg',
    features: ['Cantilevered Design', 'Infinity Pool', 'Ocean Views', 'Fire Pit Deck']
  },
  'casa-lefki': {
    name: 'Casa Lefki',
    tagline: 'Modern glass pavilion among mature Guanacaste trees',
    location: 'Lot 25, Mar Azul',
    status: 'Design',
    image: '/images/properties/casa-lefki.jpg',
    features: ['Modern Glass', 'Guanacaste Trees', 'Pool Terrace', 'Jungle Canopy Views']
  },
  'casa-umi': {
    name: 'Casa Umi',
    tagline: 'Bold contemporary design in harmony with the forest',
    location: 'Lot 34, Mar Azul',
    status: 'Design',
    image: '/images/properties/casa-umi.jpg',
    features: ['Black Charred Wood', 'Gabion Stone Walls', 'Forest Setting', 'Contemporary Design']
  },
  'casa-cacao': {
    name: 'Casa Cacao',
    tagline: 'Modern farmhouse with sweeping mountain views',
    location: 'Lot 21, Mar Azul',
    status: 'Design',
    image: '/images/properties/casa-cacao.jpg',
    features: ['Stone & Wood', 'Mountain Views', 'Modern Farmhouse', 'Open Floor Plan']
  },
  'casa-luz': {
    name: 'Casa Luz',
    tagline: 'Connected pavilions with jungle courtyards',
    location: 'Lot 21, Mar Azul',
    status: 'Design',
    image: '/images/properties/casa-luz.jpg',
    features: ['Pavilion Style', 'Stone Details', 'Jungle Compound', 'Indoor-Outdoor Living']
  }
};

const property = properties[id as string];
---

<Layout title={`${property.name} | Coyol Real Estate`}>
  <section class="hero">
    <img src={property.image} alt={property.name} />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <span class="status">{property.status}</span>
      <h1>{property.name}</h1>
      <p class="tagline">{property.tagline}</p>
      <p class="location">{property.location}</p>
    </div>
  </section>

  <section class="content">
    <div class="container">
      <div class="features-grid">
        <div class="features">
          <h2>Design Features</h2>
          <ul>
            {property.features.map((f: string) => <li>{f}</li>)}
          </ul>
        </div>
        <div class="inquiry">
          <h2>Interested?</h2>
          <p>This home is currently in the design phase. Contact us to learn more about customization options and availability.</p>
          <a href={`https://wa.me/18184018068?text=Hello%2C%20I'm%20interested%20in%20${encodeURIComponent(property.name)}`} target="_blank" class="cta-button">
            Inquire Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="back-section">
    <a href="/homesites" class="back-link">← Back to All Properties</a>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    height: 60vh;
    min-height: 400px;
    overflow: hidden;
  }

  .hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26,31,22,0.8) 0%, rgba(26,31,22,0.2) 50%);
  }

  .hero-content {
    position: absolute;
    bottom: 48px;
    left: 0;
    right: 0;
    text-align: center;
    color: #F5F3EF;
    padding: 0 24px;
  }

  .status {
    display: inline-block;
    background: #C4A67C;
    color: #1A1F16;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 8px 16px;
    border-radius: 4px;
    margin-bottom: 16px;
  }

  .hero-content h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(36px, 6vw, 60px);
    font-weight: 400;
    margin: 0 0 12px 0;
  }

  .tagline {
    font-size: 18px;
    opacity: 0.9;
    margin: 0 0 8px 0;
  }

  .location {
    font-size: 14px;
    opacity: 0.7;
  }

  .content {
    padding: 80px 24px;
    background: #F5F3EF;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
  }

  .features h2, .inquiry h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 28px;
    font-weight: 400;
    color: #1A1F16;
    margin: 0 0 24px 0;
  }

  .features ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .features li {
    font-size: 16px;
    color: #444;
    padding: 12px 0;
    border-bottom: 1px solid rgba(61,79,61,0.15);
    padding-left: 24px;
    position: relative;
  }

  .features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #3D4F3D;
  }

  .inquiry p {
    font-size: 16px;
    color: #666;
    line-height: 1.7;
    margin: 0 0 24px 0;
  }

  .cta-button {
    display: inline-block;
    background: #3D4F3D;
    color: #F5F3EF;
    padding: 16px 32px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.3s;
  }

  .cta-button:hover {
    background: #4A5D4A;
  }

  .back-section {
    padding: 40px 24px;
    background: #fff;
    text-align: center;
  }

  .back-link {
    font-size: 14px;
    color: #3D4F3D;
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 700px) {
    .features-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
