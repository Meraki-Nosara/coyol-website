---
import Layout from '../../layouts/Layout.astro';

const property = {
  name: 'Casa Elle',
  tagline: 'A completed masterpiece ready for its next chapter',
  location: 'Lot 14, Mar Azul',
  status: 'Completed',
  price: 'Price on Request',
  specs: {
    bedrooms: 4,
    bathrooms: 4,
    built: '450 m²',
    lot: '5,000 m²',
    year: 2024
  },
  features: [
    'Hacienda-style architecture',
    'Clay tile roof',
    'Exposed wood beams throughout',
    'Chef\'s kitchen with marble counters',
    'Double-height living room',
    'Modern fireplace',
    'Covered terraces',
    'Infinity pool',
    'Ocean & jungle views'
  ],
  images: [
    { src: '/images/properties/casa-elle/living-room.jpg', alt: 'Living Room', caption: 'Double-height living room with fireplace' },
    { src: '/images/properties/casa-elle/kitchen.jpg', alt: 'Kitchen', caption: 'Chef\'s kitchen with marble and brass' },
    { src: '/images/properties/casa-elle/dining.jpg', alt: 'Dining Room', caption: 'Dining room with exposed beams' },
    { src: '/images/properties/casa-elle/master-bedroom.jpg', alt: 'Master Bedroom', caption: 'Serene master suite' },
    { src: '/images/properties/casa-elle/master-bath.jpg', alt: 'Master Bath', caption: 'Spa-like master bathroom' },
    { src: '/images/properties/casa-elle/terrace.jpg', alt: 'Terrace', caption: 'Covered terrace with jungle views' },
  ],
  floorplan: '/images/floorplans/casa-elle-floorplan.jpg'
};
---

<Layout title={`${property.name} | Coyol Real Estate`}>
  <!-- Hero -->
  <section class="hero">
    <img src="/images/properties/casa-elle.jpg" alt={property.name} />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <span class="status">{property.status}</span>
      <h1>{property.name}</h1>
      <p class="tagline">{property.tagline}</p>
      <p class="location">{property.location}</p>
    </div>
  </section>

  <!-- Quick Specs -->
  <section class="specs-bar">
    <div class="container">
      <div class="spec">
        <span class="number">{property.specs.bedrooms}</span>
        <span class="label">Bedrooms</span>
      </div>
      <div class="spec">
        <span class="number">{property.specs.bathrooms}</span>
        <span class="label">Bathrooms</span>
      </div>
      <div class="spec">
        <span class="number">{property.specs.built}</span>
        <span class="label">Built Area</span>
      </div>
      <div class="spec">
        <span class="number">{property.specs.lot}</span>
        <span class="label">Lot Size</span>
      </div>
    </div>
  </section>

  <!-- Description & Features -->
  <section class="description">
    <div class="container">
      <div class="content-grid">
        <div class="main-text">
          <h2>About This Property</h2>
          <p>
            Casa Elle represents the pinnacle of tropical hacienda design, where traditional Costa Rican 
            architecture meets contemporary luxury. Set on a private 5,000 m² lot in Mar Azul, this 
            completed residence offers an extraordinary opportunity to own a move-in ready masterpiece.
          </p>
          <p>
            The home's dramatic double-height living room, anchored by a modern fireplace and framed 
            by floor-to-ceiling windows, opens to covered terraces that blur the line between indoor 
            and outdoor living. Every detail has been carefully considered—from the exposed wood beams 
            and clay tile roof to the chef's kitchen with marble counters and brass hardware.
          </p>
          <p>
            Four bedroom suites offer private retreats, with the master featuring a spa-like bathroom 
            with custom green tilework and jungle views. Outside, the infinity pool and expansive 
            terraces provide endless opportunities for entertaining or quiet contemplation.
          </p>
        </div>
        <div class="features-list">
          <h3>Features</h3>
          <ul>
            {property.features.map((feature) => (
              <li>{feature}</li>
            ))}
          </ul>
          <div class="price-box">
            <span class="price">{property.price}</span>
            <a href="https://wa.me/18184018068?text=Hello%2C%20I'm%20interested%20in%20Casa%20Elle" target="_blank" class="cta-button">
              Inquire Now
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="gallery">
    <div class="container">
      <h2>Gallery</h2>
      <div class="gallery-grid">
        {property.images.map((img) => (
          <div class="gallery-item">
            <img src={img.src} alt={img.alt} loading="lazy" />
            <span class="caption">{img.caption}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Floor Plan -->
  <section class="floorplan">
    <div class="container">
      <h2>Floor Plan</h2>
      <div class="floorplan-image">
        <img src={property.floorplan} alt={`${property.name} Floor Plan`} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Interested in Casa Elle?</h2>
      <p>Schedule a private showing to experience this exceptional property firsthand.</p>
      <a href="https://wa.me/18184018068?text=Hello%2C%20I'd%20like%20to%20schedule%20a%20showing%20of%20Casa%20Elle" target="_blank" class="cta-button">
        Schedule a Showing
      </a>
    </div>
  </section>

  <!-- Back Link -->
  <section class="back-section">
    <a href="/homesites" class="back-link">← Back to All Properties</a>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    height: 70vh;
    min-height: 500px;
    overflow: hidden;
  }

  .hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26,31,22,0.8) 0%, rgba(26,31,22,0.2) 50%, rgba(26,31,22,0.3) 100%);
  }

  .hero-content {
    position: absolute;
    bottom: 60px;
    left: 0;
    right: 0;
    text-align: center;
    color: #F5F3EF;
    padding: 0 24px;
  }

  .status {
    display: inline-block;
    background: #3D4F3D;
    color: #F5F3EF;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 8px 16px;
    border-radius: 4px;
    margin-bottom: 16px;
  }

  .hero-content h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(40px, 7vw, 72px);
    font-weight: 400;
    margin: 0 0 12px 0;
  }

  .tagline {
    font-size: 18px;
    opacity: 0.9;
    margin: 0 0 8px 0;
  }

  .location {
    font-size: 14px;
    opacity: 0.7;
    letter-spacing: 1px;
  }

  /* Specs Bar */
  .specs-bar {
    background: #1A1F16;
    padding: 32px 24px;
  }

  .specs-bar .container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 24px;
  }

  .spec {
    text-align: center;
  }

  .spec .number {
    display: block;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 28px;
    color: #C4A67C;
    margin-bottom: 4px;
  }

  .spec .label {
    font-size: 12px;
    color: rgba(245,243,239,0.7);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* Description */
  .description {
    padding: 80px 24px;
    background: #F5F3EF;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 60px;
  }

  .main-text h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 32px;
    font-weight: 400;
    color: #1A1F16;
    margin: 0 0 24px 0;
  }

  .main-text p {
    font-size: 16px;
    line-height: 1.8;
    color: #444;
    margin: 0 0 20px 0;
  }

  .features-list h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 24px;
    font-weight: 400;
    color: #1A1F16;
    margin: 0 0 16px 0;
  }

  .features-list ul {
    list-style: none;
    padding: 0;
    margin: 0 0 32px 0;
  }

  .features-list li {
    font-size: 15px;
    color: #444;
    padding: 10px 0;
    border-bottom: 1px solid rgba(61,79,61,0.15);
    padding-left: 20px;
    position: relative;
  }

  .features-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #3D4F3D;
    font-weight: bold;
  }

  .price-box {
    background: #fff;
    padding: 24px;
    border-radius: 8px;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }

  .price {
    display: block;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 24px;
    color: #1A1F16;
    margin-bottom: 16px;
  }

  .cta-button {
    display: inline-block;
    background: #3D4F3D;
    color: #F5F3EF;
    padding: 14px 28px;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.3s;
  }

  .cta-button:hover {
    background: #4A5D4A;
  }

  /* Gallery */
  .gallery {
    padding: 80px 24px;
    background: #fff;
  }

  .gallery h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 32px;
    font-weight: 400;
    color: #1A1F16;
    text-align: center;
    margin: 0 0 40px 0;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
  }

  .gallery-item img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    transition: transform 0.5s;
  }

  .gallery-item:hover img {
    transform: scale(1.05);
  }

  .gallery-item .caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
    color: #fff;
    font-size: 13px;
    padding: 40px 16px 16px;
  }

  /* Floor Plan */
  .floorplan {
    padding: 80px 24px;
    background: #1A1F16;
  }

  .floorplan h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 32px;
    font-weight: 400;
    color: #F5F3EF;
    text-align: center;
    margin: 0 0 40px 0;
  }

  .floorplan-image {
    max-width: 900px;
    margin: 0 auto;
    background: #fff;
    padding: 24px;
    border-radius: 8px;
  }

  .floorplan-image img {
    width: 100%;
    height: auto;
  }

  /* CTA Section */
  .cta-section {
    padding: 80px 24px;
    background: #F5F3EF;
    text-align: center;
  }

  .cta-section h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 36px;
    font-weight: 400;
    color: #1A1F16;
    margin: 0 0 16px 0;
  }

  .cta-section p {
    font-size: 16px;
    color: #666;
    margin: 0 0 32px 0;
  }

  /* Back Link */
  .back-section {
    padding: 40px 24px;
    background: #fff;
    text-align: center;
  }

  .back-link {
    font-size: 14px;
    color: #3D4F3D;
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  /* Mobile */
  @media (max-width: 900px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .specs-bar .container {
      justify-content: center;
    }

    .spec {
      min-width: 100px;
    }
  }
</style>
