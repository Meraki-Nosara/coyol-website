---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';

const property = {
  name: 'Casa Elle',
  location: 'Lot 14 · Mar Azul · Nosara',
  
  specs: {
    bedrooms: 4,
    bathrooms: 4,
    built: '550',
    lot: '8,261',
  },
  
  intro: 'A contemporary hacienda set within two acres of tropical forest, where traditional craft meets modern restraint.',
  
  description: [
    'Casa Elle rises from its jungle ridge with the quiet confidence of a home that knows what it is. Unhurried, considered, complete.',
    'Double-height living spaces are framed by steel-framed windows that blur the boundary between interior and canopy. A fireplace set on a concrete hearth anchors the great room beneath exposed timber beams that trace the roofline above.',
    'The kitchen speaks to serious cooking: marble surfaces, unlacquered brass, copper dome pendants. Four bedroom suites offer private retreats, with the master bath clad floor-to-ceiling in Italian-designed glazed tile.',
    'Outside, covered terraces extend living into the trees, while the pool terrace, edged in tropical planting, catches afternoon light filtering through mature Guanacaste canopy.'
  ],

  images: {
    hero: '/images/properties/casa-elle/entrance-hero.jpg',
    feature: '/images/properties/casa-elle/hero-living.jpg',
    grid: [
      '/images/properties/casa-elle/fireplace-chairs.jpg',
      '/images/properties/casa-elle/kitchen-island.jpg',
      '/images/properties/casa-elle/master-bath-vanity.jpg',
      '/images/properties/casa-elle/terrace-dining.jpg',
    ],
    gallery: [
      '/images/properties/casa-elle/pool-sunset.jpg',
      '/images/properties/casa-elle/terrace-dining.jpg',
      '/images/properties/casa-elle/pool-day.jpg',
      '/images/properties/casa-elle/bar-cabinet.jpg',
      '/images/properties/casa-elle/staircase-console.jpg',
      '/images/properties/casa-elle/living-room-wide.jpg',
      '/images/properties/casa-elle/living-arched-windows.jpg',
      '/images/properties/casa-elle/tv-room.jpg',
      '/images/properties/casa-elle/fireplace-detail.jpg',
      '/images/properties/casa-elle/living-windows.jpg',
      '/images/properties/casa-elle/living-mezzanine.jpg',
      '/images/properties/casa-elle/mezzanine-full.jpg',
      '/images/properties/casa-elle/living-art-wall.jpg',
      '/images/properties/casa-elle/kitchen-island.jpg',
      '/images/properties/casa-elle/kitchen-pantry.jpg',
      '/images/properties/casa-elle/kitchen-full.jpg',
      '/images/properties/casa-elle/kitchen-sink-lifestyle.jpg',
      '/images/properties/casa-elle/master-bedroom-full.jpg',
      '/images/properties/casa-elle/bedroom-blush.jpg',
      '/images/properties/casa-elle/study-desk.jpg',
      '/images/properties/casa-elle/master-bath-vanity.jpg',
      '/images/properties/casa-elle/master-bath-full.jpg',
      '/images/properties/casa-elle/outdoor-tub.jpg',
      '/images/properties/casa-elle/window-hardware.jpg',
    ]
  },
  
  floorplan: '/images/floorplans/casa-elle-floorplan.jpg'
};
---

<Layout title={`${property.name} | Coyol`}>
  <Navigation />
  
  <!-- Dwell-style Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=DM+Serif+Display&display=swap" rel="stylesheet" slot="head" />

  <!-- Hero -->
  <section class="hero">
    <img src={property.images.hero} alt={property.name} />
    <div class="hero-title">
      <h1>Casa Elle</h1>
    </div>
  </section>

  <!-- Header -->
  <header class="header">
    <p class="eyebrow">{property.location}</p>
    <p class="intro">{property.intro}</p>
    
    <div class="specs">
      <span>{property.specs.bedrooms} Bed</span>
      <span class="dot">·</span>
      <span>{property.specs.bathrooms} Bath</span>
      <span class="dot">·</span>
      <span>{property.specs.built} m²</span>
      <span class="dot">·</span>
      <span>{property.specs.lot} m² Lot</span>
    </div>
  </header>

  <!-- Feature Image -->
  <section class="feature-image">
    <img src={property.images.feature} alt="Living Room" />
  </section>

  <!-- Story -->
  <section class="story">
    {property.description.map((para) => (
      <p>{para}</p>
    ))}
  </section>

  <!-- Gallery -->
  <section class="gallery">
    <div class="gallery-grid">
      {property.images.gallery.map((img, i) => (
        <div class="gallery-item" data-index={i}>
          <img src={img} alt="" loading="lazy" />
        </div>
      ))}
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close">×</button>
    <button class="lightbox-prev" id="lightbox-prev">‹</button>
    <button class="lightbox-next" id="lightbox-next">›</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
    <div class="lightbox-counter" id="lightbox-counter"></div>
  </div>

  <!-- Floor Plan -->
  <section class="floorplan">
    <p class="section-label">Floor Plan</p>
    <div class="floorplan-img">
      <img src={property.floorplan} alt="Floor Plan" />
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <p class="cta-eyebrow">Private Viewings</p>
    <h2>Arrange a Visit</h2>
    <a 
      href="https://wa.me/18184018068?text=Hello%2C%20I'm%20interested%20in%20Casa%20Elle" 
      target="_blank"
      class="cta-btn"
    >
      Get in Touch
    </a>
  </section>

  <!-- Back -->
  <a href="/homesites" class="back-link">← All Properties</a>

</Layout>

<style>
  /* Dwell Typography */
  :root {
    --font-sans: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-serif: 'DM Serif Display', Georgia, serif;
    --black: #1a1a1a;
    --grey: #666;
    --light: #f7f7f5;
    --sand: #e8e4dc;
  }

  /* Hero */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
  }

  .hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-title {
    position: absolute;
    bottom: 80px;
    left: 0;
    right: 0;
    text-align: center;
  }

  .hero-title h1 {
    font-family: var(--font-serif);
    font-size: clamp(64px, 15vw, 140px);
    font-weight: 400;
    color: #fff;
    margin: 0;
    letter-spacing: 0.02em;
    text-shadow: 0 2px 40px rgba(0,0,0,0.3);
  }

  /* Header */
  .header {
    max-width: 720px;
    margin: 0 auto;
    padding: 80px 24px;
    text-align: center;
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--grey);
    margin: 0 0 20px 0;
  }

  .intro {
    font-family: var(--font-serif);
    font-size: clamp(20px, 3vw, 26px);
    color: var(--grey);
    line-height: 1.5;
    margin: 0 0 32px 0;
  }

  .specs {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--grey);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .dot {
    opacity: 0.4;
  }

  /* Feature Image */
  .feature-image {
    width: 100%;
  }

  .feature-image img {
    width: 100%;
    height: auto;
  }

  /* Story */
  .story {
    max-width: 640px;
    margin: 0 auto;
    padding: 80px 24px;
  }

  .story p {
    font-family: var(--font-sans);
    font-size: 18px;
    line-height: 1.8;
    color: var(--black);
    margin: 0 0 28px 0;
  }

  .story p:last-child {
    margin-bottom: 0;
  }

  /* Gallery */
  .gallery {
    padding: 80px 24px;
    background: var(--light);
  }

  .gallery-grid {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .gallery-item img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    transition: opacity 0.3s;
  }

  .gallery-item:hover img {
    opacity: 0.9;
  }

  .gallery-item {
    position: relative;
  }

  /* Floor Plan */
  .floorplan {
    padding: 80px 24px;
    background: var(--sand);
    text-align: center;
  }

  .section-label {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--grey);
    margin: 0 0 40px 0;
  }

  .floorplan-img {
    max-width: 900px;
    margin: 0 auto;
    background: #fff;
    padding: 24px;
  }

  .floorplan-img img {
    width: 100%;
    height: auto;
  }

  /* CTA */
  .cta {
    padding: 120px 24px;
    text-align: center;
    background: var(--black);
  }

  .cta-eyebrow {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin: 0 0 16px 0;
  }

  .cta h2 {
    font-family: var(--font-serif);
    font-size: clamp(32px, 6vw, 56px);
    font-weight: 400;
    color: #fff;
    margin: 0 0 40px 0;
  }

  .cta-btn {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--black);
    background: #fff;
    padding: 18px 48px;
    text-decoration: none;
    transition: opacity 0.3s;
  }

  .cta-btn:hover {
    opacity: 0.9;
  }

  /* Back */
  .back-link {
    display: block;
    padding: 32px 24px;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--grey);
    text-decoration: none;
    background: var(--light);
  }

  .back-link:hover {
    color: var(--black);
  }

  /* Lightbox */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: #000;
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  .lightbox.active {
    display: flex;
  }

  .lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    filter: none;
    opacity: 1;
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    background: none;
    border: none;
    color: #fff;
    font-size: 48px;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .lightbox-close:hover {
    opacity: 1;
  }

  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #fff;
    font-size: 64px;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s;
    padding: 20px;
  }

  .lightbox-prev { left: 20px; }
  .lightbox-next { right: 20px; }

  .lightbox-prev:hover,
  .lightbox-next:hover {
    opacity: 1;
  }

  .lightbox-counter {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.6);
    font-family: var(--font-sans);
    font-size: 14px;
  }

  /* Mobile */
  @media (max-width: 900px) {
    .grid-4 {
      grid-template-columns: repeat(2, 1fr);
    }

    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .grid-4 {
      grid-template-columns: 1fr;
    }

    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .header {
      padding: 60px 24px;
    }

    .story {
      padding: 60px 24px;
    }
  }
</style>

<script>
  const images = [
    '/images/properties/casa-elle/pool-sunset.jpg',
    '/images/properties/casa-elle/terrace-dining.jpg',
    '/images/properties/casa-elle/pool-day.jpg',
    '/images/properties/casa-elle/bar-cabinet.jpg',
    '/images/properties/casa-elle/staircase-console.jpg',
    '/images/properties/casa-elle/living-room-wide.jpg',
    '/images/properties/casa-elle/living-arched-windows.jpg',
    '/images/properties/casa-elle/tv-room.jpg',
    '/images/properties/casa-elle/fireplace-detail.jpg',
    '/images/properties/casa-elle/living-windows.jpg',
    '/images/properties/casa-elle/living-mezzanine.jpg',
    '/images/properties/casa-elle/mezzanine-full.jpg',
    '/images/properties/casa-elle/living-art-wall.jpg',
    '/images/properties/casa-elle/kitchen-island.jpg',
    '/images/properties/casa-elle/kitchen-pantry.jpg',
    '/images/properties/casa-elle/kitchen-full.jpg',
    '/images/properties/casa-elle/kitchen-sink-lifestyle.jpg',
    '/images/properties/casa-elle/master-bedroom-full.jpg',
    '/images/properties/casa-elle/bedroom-blush.jpg',
    '/images/properties/casa-elle/study-desk.jpg',
    '/images/properties/casa-elle/master-bath-vanity.jpg',
    '/images/properties/casa-elle/master-bath-full.jpg',
    '/images/properties/casa-elle/outdoor-tub.jpg',
    '/images/properties/casa-elle/window-hardware.jpg',
  ];

  let currentIndex = 0;

  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxCounter = document.getElementById('lightbox-counter');

  function showImage(index) {
    currentIndex = index;
    lightboxImg.src = images[index];
    lightboxCounter.textContent = `${index + 1} / ${images.length}`;
  }

  function openLightbox(index) {
    showImage(index);
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('active');
    document.body.style.overflow = '';
  }

  function nextImage() {
    showImage((currentIndex + 1) % images.length);
  }

  function prevImage() {
    showImage((currentIndex - 1 + images.length) % images.length);
  }

  // Event listeners
  document.querySelectorAll('.gallery-item').forEach((item) => {
    item.addEventListener('click', () => {
      const index = parseInt(item.dataset.index);
      openLightbox(index);
    });
  });

  document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
  document.getElementById('lightbox-next').addEventListener('click', nextImage);
  document.getElementById('lightbox-prev').addEventListener('click', prevImage);

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') nextImage();
    if (e.key === 'ArrowLeft') prevImage();
  });
</script>
