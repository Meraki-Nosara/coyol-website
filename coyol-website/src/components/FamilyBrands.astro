---
---

<!-- Family Brands Section -->
<section id="family" class="py-32 lg:py-48 bg-landrover-pangea">
  <div class="max-w-7xl mx-auto px-8">
    
    <!-- Header -->
    <div class="text-center mb-20">
      <p class="scroll-fade text-landrover-coniston text-xs tracking-[0.3em] uppercase mb-4" data-delay="0">The Family</p>
      <h2 class="scroll-fade font-serif text-4xl md:text-5xl lg:text-6xl text-landrover-santorini mb-6" data-delay="100">
        A Legacy of Hospitality
      </h2>
      <p class="scroll-fade text-landrover-marine/70 text-lg lg:text-xl max-w-3xl mx-auto" data-delay="200">
        This is a place curated by a family, shaped by decades of hosting, feeding, and caring for people in Nosara.
      </p>
    </div>

    <!-- Brand Cards -->
    <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
      
      <!-- Coyol Restaurant -->
      <article class="scroll-fade group" data-delay="0">
        <div class="img-zoom aspect-[4/3] overflow-hidden mb-6 relative">
          <img 
            src="/images/real/4.jpg"
            alt="Coyol Restaurant - Farm to table dining in Nosara"
            class="w-full h-full object-cover object-center"
          />
        </div>
        <h3 class="font-serif text-2xl lg:text-3xl text-landrover-santorini mb-3">Coyol Restaurant</h3>
        <p class="text-landrover-marine/70 leading-relaxed mb-4">
          Farm-to-table dining with panoramic views. Where local ingredients meet international flavors in an atmosphere of casual elegance.
        </p>
        <a 
          href="https://coyolrestaurant.com" 
          target="_blank"
          class="inline-flex items-center text-landrover-coniston text-sm font-medium tracking-wider uppercase hover:text-landrover-keswick transition-colors"
        >
          Visit Restaurant
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </article>

      <!-- Esh -->
      <article class="scroll-fade group" data-delay="150">
        <div class="img-zoom aspect-[4/3] overflow-hidden mb-6 relative">
          <img 
            src="/images/real/21.jpg"
            alt="Esh - Artisan bakery and bistro in Nosara"
            class="w-full h-full object-cover object-center"
          />
        </div>
        <h3 class="font-serif text-2xl lg:text-3xl text-landrover-santorini mb-3">Esh</h3>
        <p class="text-landrover-marine/70 leading-relaxed mb-4">
          Artisan bakery and bistro serving fresh-baked breads, pastries, and Mediterranean-inspired dishes in a warm, inviting space.
        </p>
        <a 
          href="https://eshnosara.com" 
          target="_blank"
          class="inline-flex items-center text-landrover-coniston text-sm font-medium tracking-wider uppercase hover:text-landrover-keswick transition-colors"
        >
          Visit Bakery
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </article>

      <!-- La Luna -->
      <article class="scroll-fade group" data-delay="300">
        <div class="img-zoom aspect-[4/3] overflow-hidden mb-6 relative">
          <img 
            src="/images/real/17.jpg"
            alt="La Luna - Beachside restaurant and bar in Nosara"
            class="w-full h-full object-cover object-center"
          />
        </div>
        <h3 class="font-serif text-2xl lg:text-3xl text-landrover-santorini mb-3">La Luna</h3>
        <p class="text-landrover-marine/70 leading-relaxed mb-4">
          Iconic beachside dining under the stars. Fresh seafood, craft cocktails, and unforgettable sunsets at Playa Pelada.
        </p>
        <a 
          href="https://lalunanosara.com" 
          target="_blank"
          class="inline-flex items-center text-landrover-coniston text-sm font-medium tracking-wider uppercase hover:text-landrover-keswick transition-colors"
        >
          Visit Restaurant
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </article>

    </div>

    <!-- Legacy Quote -->
    <div class="scroll-fade mt-20 text-center" data-delay="200">
      <blockquote class="font-serif text-2xl lg:text-3xl text-landrover-santorini/80 italic max-w-4xl mx-auto">
        "What once gathered people around tables now gathers them around homes — designed with the same intention and care."
      </blockquote>
    </div>

  </div>
</section>
