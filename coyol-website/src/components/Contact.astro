---
---

<section id="contact" class="py-24 lg:py-32 bg-landrover-limestone">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24">
      
      <!-- Left Column - Info -->
      <div>
        <p class="text-landrover-coniston text-xs tracking-[0.3em] uppercase mb-4">Get in Touch</p>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-landrover-santorini mb-6">
          Begin Your Journey
        </h2>
        <p class="text-landrover-marine/70 text-lg leading-relaxed mb-12">
          Whether you're exploring homesites, seeking a turnkey villa, or simply curious 
          about life in Nosara — we're here to guide you with discretion and care.
        </p>

        <!-- Contact Details -->
        <div class="space-y-8">
          <div>
            <h3 class="text-xs font-medium tracking-[0.2em] uppercase text-landrover-santorini mb-2">Location</h3>
            <p class="text-landrover-marine/70">Playa Guiones, Nosara<br />Guanacaste, Costa Rica</p>
          </div>
          
          <div>
            <h3 class="text-xs font-medium tracking-[0.2em] uppercase text-landrover-santorini mb-2">Email</h3>
            <a href="mailto:info@coyolrealestate.com" class="text-landrover-coniston hover:text-landrover-keswick transition-colors">
              info@coyolrealestate.com
            </a>
          </div>
          
          <div>
            <h3 class="text-xs font-medium tracking-[0.2em] uppercase text-landrover-santorini mb-2">WhatsApp</h3>
            <a href="https://wa.me/50687134120" class="text-landrover-coniston hover:text-landrover-keswick transition-colors">
              +506 8713 4120
            </a>
          </div>
          
          <div>
            <h3 class="text-xs font-medium tracking-[0.2em] uppercase text-landrover-santorini mb-2">Follow Us</h3>
            <div class="flex space-x-4">
              <a href="#" class="text-landrover-arles hover:text-landrover-coniston transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column - Form -->
      <div class="bg-landrover-pangea p-8 lg:p-12">
        <h3 class="font-serif text-2xl text-landrover-santorini mb-8">Send Us a Message</h3>
        
        <form action="#" method="POST" class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="firstName" class="block text-xs font-medium tracking-wider uppercase text-landrover-marine/70 mb-2">First Name</label>
              <input 
                type="text" 
                id="firstName" 
                name="firstName"
                class="w-full px-4 py-3 border border-landrover-arles/50 bg-landrover-alaska focus:ring-2 focus:ring-landrover-coniston focus:border-transparent outline-none transition-all"
                required
              />
            </div>
            <div>
              <label for="lastName" class="block text-xs font-medium tracking-wider uppercase text-landrover-marine/70 mb-2">Last Name</label>
              <input 
                type="text" 
                id="lastName" 
                name="lastName"
                class="w-full px-4 py-3 border border-landrover-arles/50 bg-landrover-alaska focus:ring-2 focus:ring-landrover-coniston focus:border-transparent outline-none transition-all"
                required
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-xs font-medium tracking-wider uppercase text-landrover-marine/70 mb-2">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email"
              class="w-full px-4 py-3 border border-landrover-arles/50 bg-landrover-alaska focus:ring-2 focus:ring-landrover-coniston focus:border-transparent outline-none transition-all"
              required
            />
          </div>

          <div>
            <label for="interest" class="block text-xs font-medium tracking-wider uppercase text-landrover-marine/70 mb-2">I'm Interested In</label>
            <select 
              id="interest" 
              name="interest"
              class="w-full px-4 py-3 border border-landrover-arles/50 bg-landrover-alaska focus:ring-2 focus:ring-landrover-coniston focus:border-transparent outline-none transition-all"
            >
              <option value="">Select an option</option>
              <option value="nosara-hills">Nosara Hills</option>
              <option value="mar-azul">Mar Azul</option>
              <option value="los-coyoles">Los Coyoles</option>
              <option value="villas">Turn-key Villas</option>
              <option value="general">General Information</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-xs font-medium tracking-wider uppercase text-landrover-marine/70 mb-2">Message</label>
            <textarea 
              id="message" 
              name="message"
              rows="4"
              class="w-full px-4 py-3 border border-landrover-arles/50 bg-landrover-alaska focus:ring-2 focus:ring-landrover-coniston focus:border-transparent outline-none transition-all resize-none"
            ></textarea>
          </div>

          <button 
            type="submit"
            class="w-full bg-landrover-keswick text-white px-8 py-4 text-xs font-medium tracking-[0.2em] uppercase hover:bg-landrover-coniston transition-colors"
          >
            Send Message
          </button>
        </form>
      </div>

    </div>

  </div>
</section>
