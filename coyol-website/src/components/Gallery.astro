---
const images = [
  { src: "/images/DJI_20250326172126_0411_D.jpg", alt: "Aerial view of Mar Azul", span: "lg:col-span-2 lg:row-span-2" },
  { src: "/images/casa-thatched-pool.jpg", alt: "Luxury thatched roof home with pool", span: "" },
  { src: "/images/horseback-riding.jpg", alt: "Horseback riding through Nosara", span: "" },
  { src: "/images/land-rover-greenhouse.jpg", alt: "Land Rover at the greenhouse", span: "lg:col-span-2" },
  { src: "/images/greenhouse-farm.jpg", alt: "Organic greenhouse", span: "" },
  { src: "/images/construction-team.jpg", alt: "Our construction team", span: "" },
];
---

<section id="gallery" class="py-24 lg:py-32 bg-landrover-pangea">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    
    <!-- Header -->
    <div class="max-w-3xl mb-16">
      <p class="text-landrover-coniston text-xs tracking-[0.3em] uppercase mb-4">Gallery</p>
      <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-landrover-santorini mb-6">
        Spaces That Inspire
      </h2>
      <p class="text-landrover-marine/70 text-lg leading-relaxed">
        Each design emerges naturally from its surroundings, guided by light, climate, 
        and material honesty. No repetition. No formulas. Only spaces that feel inevitable.
      </p>
    </div>

    <!-- Image Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {images.map((image) => (
        <div class={`img-zoom overflow-hidden ${image.span}`}>
          <img 
            src={image.src}
            alt={image.alt}
            class="w-full h-full object-cover aspect-square"
            loading="lazy"
          />
        </div>
      ))}
    </div>

  </div>
</section>
