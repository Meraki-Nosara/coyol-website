          -85.623,10.001,0
          -85.624,9.998,0
          -85.627,9.996,0
        </coordinates>
      </LineString>
    </Placemark>
    
    <Placemark>
      <name>Phase 3 Ridge Road</name>
      <description>6m paved - The Reserve loop</description>
      <styleUrl>#ridge-road</styleUrl>
      <LineString>
        <coordinates>
          -85.615,9.996,0
          -85.616,9.999,0
          -85.616,10.002,0
          -85.615,10.005,0
          -85.613,10.006,0
          -85.611,10.004,0
          -85.612,10.001,0
          -85.614,9.999,0
          -85.615,9.996,0
