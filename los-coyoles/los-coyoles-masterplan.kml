      <Point><coordinates>-85.636,9.994,0</coordinates></Point>
    </Placemark>
    
    <Placemark>
      <name>Racquet Club</name>
      <description>2 tennis courts, 4 pickleball courts</description>
      <styleUrl>#amenity</styleUrl>
      <Point><coordinates>-85.639,9.994,0</coordinates></Point>
    </Placemark>
    
    <Placemark>
