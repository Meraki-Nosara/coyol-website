      <LineString>
        <coordinates>
          -85.636,9.996,0
          -85.627,9.996,0
          -85.615,9.996,0
        </coordinates>
      </LineString>
    </Placemark>
    
    <Placemark>
      <name>Phase 1 Ridge Road</name>
      <description>6m paved - Serves estate lots</description>
      <styleUrl>#ridge-road</styleUrl>
      <LineString>
        <coordinates>
