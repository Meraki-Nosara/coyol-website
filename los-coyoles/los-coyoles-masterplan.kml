<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>Los Coyoles - D1 Masterplan</name>
  <description>Preliminary subdivision design - 45 homesites</description>
  
  <!-- STYLES -->
  
  <!-- Estate Lots -->
  <Style id="estate-lot">
    <IconStyle>
      <color>ff4080d4</color>
      <scale>1.2</scale>
      <Icon><href>http://maps.google.com/mapfiles/kml/shapes/homegardenbusiness.png</href></Icon>
    </IconStyle>
    <LabelStyle><scale>0.8</scale></LabelStyle>
  </Style>
  
  <!-- Hillside Lots -->
  <Style id="hillside-lot">
    <IconStyle>
      <color>ff78a8b8</color>
      <scale>1.0</scale>
      <Icon><href>http://maps.google.com/mapfiles/kml/shapes/homegardenbusiness.png</href></Icon>
    </IconStyle>
    <LabelStyle><scale>0.7</scale></LabelStyle>
  </Style>
  
  <!-- Garden Lots -->
  <Style id="garden-lot">
    <IconStyle>
      <color>ff8c9ca8</color>
      <scale>0.9</scale>
      <Icon><href>http://maps.google.com/mapfiles/kml/shapes/homegardenbusiness.png</href></Icon>
    </IconStyle>
    <LabelStyle><scale>0.7</scale></LabelStyle>
  </Style>
  
  <!-- Roads -->
  <Style id="main-road">
    <LineStyle>
      <color>ff445566</color>
      <width>6</width>
    </LineStyle>
  </Style>
  
  <Style id="ridge-road">
    <LineStyle>
      <color>ff556677</color>
      <width>4</width>
    </LineStyle>
  </Style>
  
  <!-- Amenities -->
  <Style id="amenity">
    <IconStyle>
      <color>ff00aaff</color>
      <scale>1.3</scale>
      <Icon><href>http://maps.google.com/mapfiles/kml/shapes/star.png</href></Icon>
    </IconStyle>
  </Style>
  
  <!-- Conservation -->
  <Style id="corridor">
    <PolyStyle>
      <color>6600aa00</color>
      <outline>1</outline>
    </PolyStyle>
    <LineStyle>
      <color>ff008800</color>
      <width>2</width>
    </LineStyle>
  </Style>
  
  <!-- Phases -->
  <Style id="phase1">
    <PolyStyle><color>3300ff00</color></PolyStyle>
    <LineStyle><color>ff00aa00</color><width>2</width></LineStyle>
  </Style>
  
  <Style id="phase2">
    <PolyStyle><color>33ff8800</color></PolyStyle>
    <LineStyle><color>ffcc6600</color><width>2</width></LineStyle>
  </Style>
  
  <Style id="phase3">
    <PolyStyle><color>330088ff</color></PolyStyle>
    <LineStyle><color>ff0066cc</color><width>2</width></LineStyle>
  </Style>

  <!-- ============================================ -->
  <!-- PHASE BOUNDARIES -->
  <!-- ============================================ -->
  
  <Folder>
    <name>Phase Boundaries</name>
    
    <Placemark>
      <name>Phase 1: The Sunset Ridge</name>
      <description>32 hectares - 18 homesites - Best sunset views</description>
      <styleUrl>#phase1</styleUrl>
      <Polygon>
        <outerBoundaryIs>
          <LinearRing>
            <coordinates>
              -85.643,9.992,0
              -85.643,10.007,0
              -85.632,10.007,0
              -85.632,9.992,0
              -85.643,9.992,0
            </coordinates>
          </LinearRing>
        </outerBoundaryIs>
      </Polygon>
    </Placemark>
    
    <Placemark>
      <name>Phase 2: The Panorama</name>
      <description>34 hectares - 15 homesites - 360° views</description>
      <styleUrl>#phase2</styleUrl>
      <Polygon>
        <outerBoundaryIs>
          <LinearRing>
            <coordinates>
              -85.632,9.992,0
              -85.632,10.007,0
              -85.620,10.007,0
              -85.620,9.992,0
              -85.632,9.992,0
            </coordinates>
          </LinearRing>
        </outerBoundaryIs>
      </Polygon>
    </Placemark>
    
    <Placemark>
      <name>Phase 3: The Reserve</name>
      <description>25 hectares - 12 homesites - Nature-forward</description>
      <styleUrl>#phase3</styleUrl>
      <Polygon>
        <outerBoundaryIs>
          <LinearRing>
            <coordinates>
              -85.620,9.992,0
              -85.620,10.007,0
              -85.610,10.007,0
              -85.610,9.992,0
              -85.620,9.992,0
            </coordinates>
          </LinearRing>
        </outerBoundaryIs>
      </Polygon>
    </Placemark>
  </Folder>

  <!-- ============================================ -->
  <!-- BIOLOGICAL CORRIDOR -->
  <!-- ============================================ -->
  
  <Folder>
    <name>Conservation</name>
    
    <Placemark>
      <name>Biological Corridor</name>
      <description>~36 hectares protected - Quebradas and riparian habitat</description>
      <styleUrl>#corridor</styleUrl>
      <Polygon>
        <outerBoundaryIs>
          <LinearRing>
            <coordinates>
              -85.643,9.9925,0
              -85.610,9.9935,0
              -85.610,9.987,0
              -85.643,9.987,0
              -85.643,9.9925,0
            </coordinates>
          </LinearRing>
        </outerBoundaryIs>
      </Polygon>
    </Placemark>
  </Folder>

  <!-- ============================================ -->
  <!-- ROAD NETWORK -->
  <!-- ============================================ -->
  
  <Folder>
    <name>Roads</name>
    
    <Placemark>
      <name>Main Entry Road</name>
      <description>8m paved - Connection from Mar Azul</description>
      <styleUrl>#main-road</styleUrl>
      <LineString>
        <coordinates>
          -85.645,9.996,0
          -85.636,9.996,0
        </coordinates>
      </LineString>
    </Placemark>
    
    <Placemark>
      <name>Spine Road</name>
      <description>8m paved - Main artery through all phases</description>
