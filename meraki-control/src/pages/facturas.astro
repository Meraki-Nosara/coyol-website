---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

// Load facturas data
const dataDir = path.join(process.cwd(), 'data');
const facturasPath = path.join(dataDir, 'facturas.json');
const suppliersPath = path.join(dataDir, 'suppliers.json');

let facturas: any = { facturas: [], totals: {} };
let suppliers: any = { suppliers: {} };

if (fs.existsSync(facturasPath)) {
  facturas = JSON.parse(fs.readFileSync(facturasPath, 'utf8'));
}
if (fs.existsSync(suppliersPath)) {
  suppliers = JSON.parse(fs.readFileSync(suppliersPath, 'utf8'));
}

// Handle POST for assignment
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const supplierId = formData.get('supplierId') as string;
  const restaurant = formData.get('restaurant') as string;
  
  if (supplierId && restaurant && suppliers.suppliers[supplierId]) {
    // Update supplier mapping
    suppliers.suppliers[supplierId].restaurant = restaurant;
    fs.writeFileSync(suppliersPath, JSON.stringify(suppliers, null, 2));
    
    // Update all facturas from this supplier
    facturas.facturas = facturas.facturas.map((f: any) => {
      if (f.supplierId === supplierId) {
        f.restaurant = restaurant;
      }
      return f;
    });
    
    // Recalculate totals
    facturas.totals = {};
    facturas.facturas.forEach((f: any) => {
      const month = f.fecha ? f.fecha.substring(0, 7) : 'unknown';
      if (!facturas.totals[month]) {
        facturas.totals[month] = { total: 0, count: 0, byRestaurant: {}, bySupplier: {} };
      }
      facturas.totals[month].total += f.total;
      facturas.totals[month].count += 1;
      
      if (!facturas.totals[month].byRestaurant[f.restaurant]) {
        facturas.totals[month].byRestaurant[f.restaurant] = 0;
      }
      facturas.totals[month].byRestaurant[f.restaurant] += f.total;
    });
    
    fs.writeFileSync(facturasPath, JSON.stringify(facturas, null, 2));
    
    // Redirect to refresh
    return Astro.redirect('/facturas?saved=1');
  }
}

// Get URL params
const url = new URL(Astro.request.url);
const saved = url.searchParams.get('saved');
const filterRestaurant = url.searchParams.get('filter') || 'all';

// Format currency
const formatCurrency = (amount: number) => {
  return '₡' + Math.round(amount).toLocaleString();
};

// Get unassigned facturas (restaurant = unknown or shared)
const unassignedFacturas = facturas.facturas.filter((f: any) => 
  f.restaurant === 'unknown' || f.restaurant === 'shared'
);

// Get all facturas filtered
const filteredFacturas = filterRestaurant === 'all' 
  ? facturas.facturas 
  : filterRestaurant === 'unassigned'
    ? unassignedFacturas
    : facturas.facturas.filter((f: any) => f.restaurant === filterRestaurant);

// Group by supplier for bulk assignment
const supplierGroups = unassignedFacturas.reduce((acc: any, f: any) => {
  if (!acc[f.supplierId]) {
    acc[f.supplierId] = {
      supplierId: f.supplierId,
      supplierName: f.supplierName,
      invoices: [],
      total: 0
    };
  }
  acc[f.supplierId].invoices.push(f);
  acc[f.supplierId].total += f.total;
  return acc;
}, {});

const unassignedSuppliers = Object.values(supplierGroups).sort((a: any, b: any) => b.total - a.total);

// Stats
const stats = {
  total: facturas.facturas.length,
  unassigned: unassignedFacturas.length,
  laluna: facturas.facturas.filter((f: any) => f.restaurant === 'laluna').length,
  coyol: facturas.facturas.filter((f: any) => f.restaurant === 'coyol').length,
  esh: facturas.facturas.filter((f: any) => f.restaurant === 'esh').length,
};

const restaurantColors: Record<string, string> = {
  laluna: '#A65D3F',
  coyol: '#3D4F3D',
  esh: '#C4A67C',
  unknown: '#999',
  shared: '#666'
};
---

<Layout title="Facturas">
  <div class="min-h-screen flex">
    <!-- Sidebar -->
    <aside class="w-64 bg-landrover-keswick text-white flex-shrink-0 hidden lg:flex lg:flex-col">
      <div class="p-6">
        <h1 class="font-serif text-2xl font-semibold tracking-wide">Meraki</h1>
        <p class="text-landrover-limestone/60 text-xs mt-1">Financial Control</p>
      </div>
      
      <nav class="mt-4 flex-1">
        <a href="/mensual" class="flex items-center gap-3 px-6 py-3 text-landrover-limestone/80 hover:bg-white/5 hover:text-white transition-colors border-l-4 border-transparent">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
          <span class="text-sm">Dashboard</span>
        </a>
        
        <a href="/reportes" class="flex items-center gap-3 px-6 py-3 text-landrover-limestone/80 hover:bg-white/5 hover:text-white transition-colors border-l-4 border-transparent">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="text-sm">Reports</span>
        </a>
        
        <a href="/facturas" class="flex items-center gap-3 px-6 py-3 bg-white/10 text-white border-l-4 border-landrover-sand">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="text-sm font-medium">Facturas</span>
          {stats.unassigned > 0 && (
            <span class="ml-auto bg-red-500 text-white text-xs px-2 py-0.5 rounded-full">{stats.unassigned}</span>
          )}
        </a>
        
        <a href="/obligaciones" class="flex items-center gap-3 px-6 py-3 text-landrover-limestone/80 hover:bg-white/5 hover:text-white transition-colors border-l-4 border-transparent">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span class="text-sm">Obligaciones</span>
        </a>
      </nav>
      
      <!-- User & Logout -->
      <div class="p-6 border-t border-white/10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-landrover-sand rounded-full flex items-center justify-center text-landrover-keswick font-semibold">
              AP
            </div>
            <div>
              <p class="text-sm font-medium">Angelina</p>
              <p class="text-xs text-landrover-limestone/60">Admin</p>
            </div>
          </div>
          <a href="/logout" class="text-landrover-limestone/60 hover:text-white transition-colors" title="Log out">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
          </a>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-auto">
      <!-- Header -->
      <header class="bg-white border-b border-landrover-arles/30 sticky top-0 z-40">
        <div class="px-4 lg:px-8 py-4">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-xl font-semibold text-landrover-santorini">Supplier Invoices</h2>
              <p class="text-sm text-landrover-marine/60">Assign invoices to restaurants</p>
            </div>
            
            {saved && (
              <div class="bg-green-100 text-green-700 px-4 py-2 rounded text-sm">
                ✓ Supplier assigned successfully
              </div>
            )}
          </div>
        </div>
      </header>

      <div class="p-4 lg:p-8 space-y-6">
        
        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
          <div class="card p-4 text-center">
            <p class="text-2xl font-bold text-landrover-santorini">{stats.total}</p>
            <p class="text-xs text-landrover-marine/60">Total</p>
          </div>
          <div class="card p-4 text-center border-2 border-red-200">
            <p class="text-2xl font-bold text-red-500">{stats.unassigned}</p>
            <p class="text-xs text-landrover-marine/60">Unassigned</p>
          </div>
          <div class="card p-4 text-center">
            <div class="w-3 h-3 rounded mx-auto mb-1" style="background-color: #A65D3F"></div>
            <p class="text-2xl font-bold">{stats.laluna}</p>
            <p class="text-xs text-landrover-marine/60">La Luna</p>
          </div>
          <div class="card p-4 text-center">
            <div class="w-3 h-3 rounded mx-auto mb-1" style="background-color: #3D4F3D"></div>
            <p class="text-2xl font-bold">{stats.coyol}</p>
            <p class="text-xs text-landrover-marine/60">Coyol</p>
          </div>
          <div class="card p-4 text-center">
            <div class="w-3 h-3 rounded mx-auto mb-1" style="background-color: #C4A67C"></div>
            <p class="text-2xl font-bold">{stats.esh}</p>
            <p class="text-xs text-landrover-marine/60">Esh</p>
          </div>
        </div>

        <!-- Unassigned Suppliers (Priority) -->
        {unassignedSuppliers.length > 0 && (
          <div class="card">
            <div class="px-4 lg:px-6 py-3 lg:py-4 border-b border-landrover-arles/30 bg-red-50">
              <h3 class="font-semibold text-red-700">⚠️ Unassigned Suppliers ({unassignedSuppliers.length})</h3>
              <p class="text-sm text-red-600/70">Assign these suppliers to a restaurant. All their invoices will be updated.</p>
            </div>
            
            <div class="divide-y divide-landrover-arles/20">
              {(unassignedSuppliers as any[]).map((supplier) => (
                <div class="p-4 flex flex-col lg:flex-row lg:items-center gap-4">
                  <div class="flex-1">
                    <p class="font-semibold text-landrover-santorini">{supplier.supplierName}</p>
                    <p class="text-sm text-landrover-marine/60">
                      {supplier.invoices.length} invoice{supplier.invoices.length !== 1 ? 's' : ''} • 
                      {formatCurrency(supplier.total)}
                    </p>
                  </div>
                  
                  <form method="POST" class="flex gap-2">
                    <input type="hidden" name="supplierId" value={supplier.supplierId} />
                    
                    <button 
                      type="submit" 
                      name="restaurant" 
                      value="laluna"
                      class="px-4 py-2 text-sm font-medium rounded transition-colors hover:opacity-80"
                      style="background-color: #A65D3F; color: white;"
                    >
                      La Luna
                    </button>
                    <button 
                      type="submit" 
                      name="restaurant" 
                      value="coyol"
                      class="px-4 py-2 text-sm font-medium rounded transition-colors hover:opacity-80"
                      style="background-color: #3D4F3D; color: white;"
                    >
                      Coyol
                    </button>
                    <button 
                      type="submit" 
                      name="restaurant" 
                      value="esh"
                      class="px-4 py-2 text-sm font-medium rounded transition-colors hover:opacity-80"
                      style="background-color: #C4A67C; color: white;"
                    >
                      Esh
                    </button>
                    <button 
                      type="submit" 
                      name="restaurant" 
                      value="shared"
                      class="px-4 py-2 text-sm font-medium rounded transition-colors bg-gray-200 text-gray-700 hover:bg-gray-300"
                    >
                      Shared
                    </button>
                  </form>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- All Facturas List -->
        <div class="card">
          <div class="px-4 lg:px-6 py-3 lg:py-4 border-b border-landrover-arles/30 flex items-center justify-between">
            <h3 class="font-semibold text-landrover-santorini">All Invoices</h3>
            
            <!-- Filter -->
            <div class="flex gap-2">
              <a href="/facturas?filter=all" class={`px-3 py-1 text-xs rounded ${filterRestaurant === 'all' ? 'bg-landrover-keswick text-white' : 'bg-landrover-limestone/50'}`}>All</a>
              <a href="/facturas?filter=unassigned" class={`px-3 py-1 text-xs rounded ${filterRestaurant === 'unassigned' ? 'bg-red-500 text-white' : 'bg-landrover-limestone/50'}`}>Unassigned</a>
              <a href="/facturas?filter=laluna" class={`px-3 py-1 text-xs rounded ${filterRestaurant === 'laluna' ? 'text-white' : 'bg-landrover-limestone/50'}`} style={filterRestaurant === 'laluna' ? 'background-color: #A65D3F' : ''}>La Luna</a>
              <a href="/facturas?filter=coyol" class={`px-3 py-1 text-xs rounded ${filterRestaurant === 'coyol' ? 'text-white' : 'bg-landrover-limestone/50'}`} style={filterRestaurant === 'coyol' ? 'background-color: #3D4F3D' : ''}>Coyol</a>
              <a href="/facturas?filter=esh" class={`px-3 py-1 text-xs rounded ${filterRestaurant === 'esh' ? 'text-white' : 'bg-landrover-limestone/50'}`} style={filterRestaurant === 'esh' ? 'background-color: #C4A67C' : ''}>Esh</a>
            </div>
          </div>
          
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-landrover-arles/30">
                  <th class="px-4 py-3 text-left font-medium text-landrover-marine/60">Date</th>
                  <th class="px-4 py-3 text-left font-medium text-landrover-marine/60">Supplier</th>
                  <th class="px-4 py-3 text-right font-medium text-landrover-marine/60">Amount</th>
                  <th class="px-4 py-3 text-center font-medium text-landrover-marine/60">Restaurant</th>
                </tr>
              </thead>
              <tbody>
                {filteredFacturas.slice(0, 50).map((f: any) => (
                  <tr class="border-b border-landrover-arles/10 hover:bg-landrover-limestone/20">
                    <td class="px-4 py-3 text-landrover-marine/60">
                      {f.fecha ? new Date(f.fecha).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '-'}
                    </td>
                    <td class="px-4 py-3 font-medium">{f.supplierName}</td>
                    <td class="px-4 py-3 text-right font-semibold">{formatCurrency(f.total)}</td>
                    <td class="px-4 py-3 text-center">
                      <span 
                        class="px-2 py-1 text-xs rounded text-white"
                        style={`background-color: ${restaurantColors[f.restaurant] || '#999'}`}
                      >
                        {f.restaurant === 'laluna' ? 'La Luna' : f.restaurant === 'unknown' ? '❓' : f.restaurant.charAt(0).toUpperCase() + f.restaurant.slice(1)}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          
          {filteredFacturas.length > 50 && (
            <div class="px-4 py-3 text-center text-sm text-landrover-marine/60">
              Showing 50 of {filteredFacturas.length} invoices
            </div>
          )}
        </div>
      </div>
    </main>
  </div>
</Layout>
