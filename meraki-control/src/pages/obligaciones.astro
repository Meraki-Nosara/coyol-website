          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
          <span class="text-sm">PDF Reports</span>
        </a>
        
        <a href="/facturas" class="flex items-center gap-3 px-6 py-3 text-landrover-limestone/80 hover:bg-white/5 hover:text-white transition-colors border-l-4 border-transparent">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="text-sm">Facturas</span>
        </a>
        
        <a href="/obligaciones" class="flex items-center gap-3 px-6 py-3 bg-white/10 text-white border-l-4 border-landrover-sand">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span class="text-sm font-medium">Obligaciones</span>
        </a>
      </nav>
      
      <!-- User & Logout -->
      <div class="p-6 border-t border-white/10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-landrover-sand rounded-full flex items-center justify-center text-landrover-keswick font-semibold">
              AP
            </div>
            <div>
              <p class="text-sm font-medium">Angelina</p>
              <p class="text-xs text-landrover-limestone/60">Admin</p>
            </div>
          </div>
          <a href="/logout" class="text-landrover-limestone/60 hover:text-white transition-colors" title="Log out">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
          </a>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-auto">
      <!-- Mobile Header -->
      <header class="lg:hidden bg-landrover-keswick text-white p-4 flex items-center justify-between">
        <h1 class="font-serif text-xl font-semibold">Meraki</h1>
        <a href="/logout" class="text-landrover-limestone/80">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
        </a>
      </header>
      
      <div class="p-6 lg:p-8">
        <!-- Page Header -->
        <div class="mb-8">
          <h2 class="text-2xl lg:text-3xl font-serif font-semibold text-landrover-santorini">Obligaciones Tributarias</h2>
          <p class="text-landrover-santorini/60 mt-1">Calendario de impuestos y pagos obligatorios</p>
        </div>

        <!-- Alert Summary -->
        {(overdue.length > 0 || dueSoon.length > 0) && (
          <div class="mb-8 p-4 rounded-xl bg-red-50 border border-red-200">
            <div class="flex items-start gap-3">
              <div class="text-2xl">⚠️</div>
              <div>
                <h3 class="font-semibold text-red-800">Atención Requerida</h3>
                <p class="text-red-700 text-sm mt-1">
                  {overdue.length > 0 && <span class="font-medium">{overdue.length} vencido{overdue.length > 1 ? 's' : ''}</span>}
                  {overdue.length > 0 && dueSoon.length > 0 && ' • '}
                  {dueSoon.length > 0 && <span>{dueSoon.length} por vencer</span>}
                </p>
              </div>
            </div>
          </div>
        )}

        <!-- Summary Cards -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
          <div class="bg-amber-50 border-2 border-amber-300 rounded-xl p-5">
            <div class="flex items-center justify-between">
              <div>
                <div class="text-sm text-amber-700 font-medium">Pendiente de Pago</div>
                <div class="text-2xl lg:text-3xl font-bold text-amber-800">₡{totalPending.toLocaleString()}</div>
              </div>
              <div class="text-4xl">💳</div>
            </div>
          </div>
          <div class="bg-green-50 border-2 border-green-300 rounded-xl p-5">
            <div class="flex items-center justify-between">
              <div>
                <div class="text-sm text-green-700 font-medium">Pagado en Abril</div>
                <div class="text-2xl lg:text-3xl font-bold text-green-800">₡{totalPaidThisMonth.toLocaleString()}</div>
              </div>
              <div class="text-4xl">✅</div>
            </div>
          </div>
        </div>

        <!-- Renta Forecast -->
        {q1Profit > 0 && (
          <div class="mb-8 p-6 rounded-xl bg-gradient-to-br from-purple-50 to-indigo-50 border-2 border-purple-200">
            <div class="flex items-center gap-3 mb-4">
              <div class="text-3xl">📊</div>
              <div>
                <h3 class="text-lg font-semibold text-purple-900">Proyección Renta 2026</h3>
                <p class="text-sm text-purple-600">Basado en Q1 2026 y datos históricos</p>
              </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-4">
              <div class="bg-white/70 rounded-lg p-4">
                <div class="text-xs text-purple-600 font-medium">Utilidad Q1 2026</div>
                <div class="text-xl font-bold text-purple-900">₡{(q1Profit/1000000).toFixed(1)}M</div>
              </div>
              <div class="bg-white/70 rounded-lg p-4">
                <div class="text-xs text-purple-600 font-medium">Proyección Anual</div>
                <div class="text-xl font-bold text-purple-900">₡{(projectedAnnualProfit/1000000).toFixed(1)}M</div>
                <div class="text-xs text-purple-500">Ajustado por estacionalidad</div>
              </div>
              <div class="bg-white/70 rounded-lg p-4 border-2 border-purple-300">
                <div class="text-xs text-purple-600 font-medium">Renta Estimada</div>
                <div class="text-xl font-bold text-purple-900">₡{(estimatedRenta/1000000).toFixed(1)}M</div>
                <div class="text-xs {rentaChange > 0 ? 'text-red-500' : 'text-green-500'}">
                  {rentaChange > 0 ? '↑' : '↓'} {Math.abs(rentaChange).toFixed(0)}% vs 2025
                </div>
              </div>
              <div class="bg-purple-100 rounded-lg p-4">
                <div class="text-xs text-purple-600 font-medium">Provisión Mensual</div>
                <div class="text-xl font-bold text-purple-900">₡{(monthlyProvision/1000000).toFixed(2)}M</div>
                <div class="text-xs text-purple-500">Recomendado apartar</div>
              </div>
            </div>
            
            <div class="text-xs text-purple-600 bg-white/50 rounded-lg p-3">
              <strong>💡 Nota:</strong> Q1 es temporada alta (~35% de ingresos anuales). 
              Proyección conservadora considera baja temporada Q2-Q3. 
              Renta 2025 pagada: ₡{(lastYearRenta/1000000).toFixed(1)}M.
              <br/><strong>Próximo pago:</strong> 3 anticipos trimestrales de ~₡{(estimatedRenta/4/1000000).toFixed(1)}M cada uno.
            </div>
          </div>
        )}

        <!-- Status Cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
          <div class="bg-red-50 border border-red-200 rounded-xl p-4 text-center">
            <div class="text-3xl font-bold text-red-700">{overdue.length}</div>
            <div class="text-sm text-red-600">Vencidos</div>
          </div>
          <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-center">
            <div class="text-3xl font-bold text-amber-700">{dueSoon.length}</div>
            <div class="text-sm text-amber-600">Por vencer</div>
          </div>
          <div class="bg-landrover-limestone rounded-xl p-4 text-center border border-landrover-coniston/20">
            <div class="text-3xl font-bold text-landrover-santorini">{upcoming.length}</div>
            <div class="text-sm text-landrover-santorini/70">Próximos</div>
          </div>
          <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-center">
            <div class="text-3xl font-bold text-green-700">{paid.length}</div>
            <div class="text-sm text-green-600">Al día</div>
          </div>
        </div>

        <!-- Obligations List -->
        <div class="space-y-4">
          {statuses.map(({ obligation, nextDue, status, statusColor, statusText, period }) => (
            <div class={`bg-white rounded-xl border-2 p-5 transition-all hover:shadow-md ${
