---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

// Load P&L data for Renta estimate
const salesDataPath = path.join(process.cwd(), 'data/sales.json');
const gastosDataPath = path.join(process.cwd(), 'data/gastos.json');

let q1Profit = 0;
let lastYearRenta = 19246723; // From accountant data - Renta 2025 paid

try {
  // Q1 2026 P&L from accountant:
  // Enero: Ventas ₡345.0M, Utilidad ₡184.3M
  // Febrero: Ventas ₡291.2M, Utilidad ₡131.7M
  // Marzo: Ventas ₡347.9M, Utilidad ₡160.2M
  // Total Q1: ₡984.1M ventas, ₡476.2M utilidad
  q1Profit = 476200000; // From P&L images
} catch (e) {
  q1Profit = 0;
}

// Costa Rica tax brackets for companies (2025-2026)
// Up to ₡5,761,000: 5%
// ₡5,761,001 - ₡8,643,000: 10%
// ₡8,643,001 - ₡17,286,000: 15%
// ₡17,286,001 - ₡34,572,000: 20%
// Over ₡34,572,000: 30%

const calculateRenta = (annualProfit: number): number => {
  if (annualProfit <= 0) return 0;
  
  let tax = 0;
  const brackets = [
    { limit: 5761000, rate: 0.05 },
    { limit: 8643000, rate: 0.10 },
    { limit: 17286000, rate: 0.15 },
    { limit: 34572000, rate: 0.20 },
    { limit: Infinity, rate: 0.30 }
  ];
  
  let remaining = annualProfit;
  let prevLimit = 0;
  
  for (const bracket of brackets) {
    const taxableInBracket = Math.min(remaining, bracket.limit - prevLimit);
    if (taxableInBracket <= 0) break;
    tax += taxableInBracket * bracket.rate;
    remaining -= taxableInBracket;
    prevLimit = bracket.limit;
  }
  
  return tax;
};

// Seasonal adjustment: Q1 is high season (35% of annual), rest is 65%
const seasonalMultiplier = 1 / 0.35; // Q1 represents ~35% of annual revenue
const projectedAnnualProfit = q1Profit * seasonalMultiplier * 0.85; // Conservative 15% reduction
const estimatedRenta = calculateRenta(projectedAnnualProfit);
const monthlyProvision = Math.ceil(estimatedRenta / 12);

// Comparison with last year
const rentaChange = lastYearRenta > 0 ? ((estimatedRenta - lastYearRenta) / lastYearRenta * 100) : 0;

// Load obligations data
const dataPath = path.join(process.cwd(), 'data/obligaciones.json');
let obligations: Array<{
  id: string;
  name: string;
  type: 'iva' | 'renta' | 'ccss' | 'patente' | 'other';
  frequency: 'monthly' | 'quarterly' | 'annual';
  dueDay: number;
  dueMonth?: number;
  description: string;
  haciendaCode?: string;
  amount?: number;
  period?: string;
  status?: 'pending' | 'paid' | 'adjustment' | 'recurring';
  lastPaid?: string;
  lastPaidAmount?: number;
  notes?: string;
}> = [];

const defaultObligations = [
  {
    id: 'iva-d104',
    name: 'IVA (D-104)',
    type: 'iva' as const,
    frequency: 'monthly' as const,
    dueDay: 15,
    description: 'Declaración y pago del Impuesto al Valor Agregado',
    haciendaCode: 'D-104'
  },
  {
    id: 'ccss-patronal',
    name: 'CCSS Patronal',
    type: 'ccss' as const,
    frequency: 'monthly' as const,
    dueDay: 15,
    description: 'Cuotas obrero-patronales de la Caja'
  },
  {
    id: 'renta-d101',
    name: 'Renta (D-101)',
    type: 'renta' as const,
    frequency: 'annual' as const,
    dueDay: 15,
    dueMonth: 12,
    description: 'Declaración anual del Impuesto sobre la Renta',
    haciendaCode: 'D-101'
  },
  {
    id: 'patente-nosara',
    name: 'Patente Municipal',
    type: 'patente' as const,
    frequency: 'quarterly' as const,
    dueDay: 1,
    description: 'Licencia comercial - Municipalidad de Nicoya'
  },
  {
    id: 'd151-clientes',
    name: 'D-151 Clientes',
    type: 'other' as const,
    frequency: 'annual' as const,
    dueDay: 30,
    dueMonth: 11,
    description: 'Declaración informativa de clientes y proveedores',
    haciendaCode: 'D-151'
  }
];

if (fs.existsSync(dataPath)) {
  try {
    obligations = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));
  } catch (e) {
    obligations = defaultObligations;
  }
} else {
  obligations = defaultObligations;
}

// Calculate status for each obligation
const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth() + 1;
const currentDay = now.getDate();

interface ObligationStatus {
  obligation: typeof obligations[0];
  nextDue: Date;
  daysUntilDue: number;
  status: 'overdue' | 'due-soon' | 'upcoming' | 'paid';
  statusColor: string;
  statusText: string;
  period: string;
}

const getObligationStatus = (obl: typeof obligations[0]): ObligationStatus => {
  let nextDue: Date;
  let period: string;
  
  // If obligation has explicit status, use it
  if (obl.status === 'paid') {
    nextDue = obl.lastPaid ? new Date(obl.lastPaid) : now;
    period = obl.period || '';
    return {
      obligation: obl,
      nextDue,
      daysUntilDue: 0,
      status: 'paid',
      statusColor: 'bg-green-100 text-green-800 border-green-300',
      statusText: '✓ Pagado',
      period
    };
  }
  
  if (obl.status === 'adjustment') {
    nextDue = now;
    period = obl.period || '';
    return {
      obligation: obl,
      nextDue,
      daysUntilDue: 999,
      status: 'upcoming',
      statusColor: 'bg-gray-100 text-gray-600 border-gray-300',
      statusText: '📋 Ajuste',
      period
    };
  }
  
  if (obl.status === 'pending' && obl.dueMonth) {
    // Explicit pending with due date
    nextDue = new Date(currentYear, obl.dueMonth - 1, obl.dueDay);
    period = obl.period || '';
    const daysUntilDue = Math.ceil((nextDue.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
    
    let status: 'overdue' | 'due-soon' | 'upcoming' | 'paid' = 'upcoming';
    let statusColor = 'bg-landrover-limestone text-landrover-santorini border-landrover-coniston/30';
    let statusText = `${daysUntilDue} días`;
    
    if (daysUntilDue < 0) {
      status = 'overdue';
      statusColor = 'bg-red-100 text-red-800 border-red-300';
      statusText = `⚠️ Vencido hace ${Math.abs(daysUntilDue)} días`;
    } else if (daysUntilDue <= 5) {
      status = 'due-soon';
      statusColor = 'bg-amber-100 text-amber-800 border-amber-300';
      statusText = daysUntilDue === 0 ? '⏰ Vence HOY' : `⏰ ${daysUntilDue} días`;
    }
    
    return { obligation: obl, nextDue, daysUntilDue, status, statusColor, statusText, period };
  }
  
  // Recurring obligations without explicit status
  if (obl.frequency === 'monthly') {
    if (currentDay <= obl.dueDay) {
      nextDue = new Date(currentYear, currentMonth - 1, obl.dueDay);
      period = new Date(currentYear, currentMonth - 2, 1).toLocaleDateString('es-CR', { month: 'long', year: 'numeric' });
    } else {
      nextDue = new Date(currentYear, currentMonth, obl.dueDay);
      period = new Date(currentYear, currentMonth - 1, 1).toLocaleDateString('es-CR', { month: 'long', year: 'numeric' });
    }
  } else if (obl.frequency === 'quarterly') {
    const quarterDues = [
      { month: 4, quarter: 'Q1' },
      { month: 7, quarter: 'Q2' },
      { month: 10, quarter: 'Q3' },
      { month: 1, quarter: 'Q4' }
    ];
    const nextQuarter = quarterDues.find(q => 
      q.month > currentMonth || (q.month === currentMonth && currentDay <= obl.dueDay)
    ) || quarterDues[0];
    const year = nextQuarter.month < currentMonth ? currentYear + 1 : currentYear;
    nextDue = new Date(year, nextQuarter.month - 1, obl.dueDay);
    period = nextQuarter.quarter + ' ' + (nextQuarter.month === 1 ? year - 1 : year);
  } else {
    const dueMonth = obl.dueMonth || 12;
    if (currentMonth < dueMonth || (currentMonth === dueMonth && currentDay <= obl.dueDay)) {
      nextDue = new Date(currentYear, dueMonth - 1, obl.dueDay);
    } else {
      nextDue = new Date(currentYear + 1, dueMonth - 1, obl.dueDay);
    }
    period = 'Año fiscal ' + (nextDue.getFullYear() - 1);
  }
  
  const daysUntilDue = Math.ceil((nextDue.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
  
  let isPaid = false;
  if (obl.lastPaid) {
    const lastPaidDate = new Date(obl.lastPaid);
    if (obl.frequency === 'monthly') {
      isPaid = lastPaidDate >= new Date(currentYear, currentMonth - 2, 1);
    } else if (obl.frequency === 'annual') {
      isPaid = lastPaidDate.getFullYear() === currentYear;
    }
  }
  
  let status: 'overdue' | 'due-soon' | 'upcoming' | 'paid';
  let statusColor: string;
  let statusText: string;
  
  if (isPaid) {
    status = 'paid';
    statusColor = 'bg-green-100 text-green-800 border-green-300';
    statusText = '✓ Al día';
  } else if (daysUntilDue < 0) {
    status = 'overdue';
    statusColor = 'bg-red-100 text-red-800 border-red-300';
    statusText = `⚠️ Vencido hace ${Math.abs(daysUntilDue)} días`;
  } else if (daysUntilDue <= 5) {
    status = 'due-soon';
    statusColor = 'bg-amber-100 text-amber-800 border-amber-300';
    statusText = daysUntilDue === 0 ? '⏰ Vence HOY' : `⏰ Vence en ${daysUntilDue} días`;
  } else {
    status = 'upcoming';
    statusColor = 'bg-landrover-limestone text-landrover-santorini border-landrover-coniston/30';
    statusText = `${daysUntilDue} días`;
  }
  
  return { obligation: obl, nextDue, daysUntilDue, status, statusColor, statusText, period };
};

const statuses = obligations.map(getObligationStatus).sort((a, b) => a.daysUntilDue - b.daysUntilDue);

const overdue = statuses.filter(s => s.status === 'overdue');
const dueSoon = statuses.filter(s => s.status === 'due-soon');
const upcoming = statuses.filter(s => s.status === 'upcoming');
const paid = statuses.filter(s => s.status === 'paid');

// Calculate totals
const totalPending = statuses
  .filter(s => s.status !== 'paid' && s.obligation.amount)
  .reduce((sum, s) => sum + (s.obligation.amount || 0), 0);
const totalPaidThisMonth = statuses
  .filter(s => s.status === 'paid' && s.obligation.lastPaid && new Date(s.obligation.lastPaid).getMonth() === currentMonth - 1)
  .reduce((sum, s) => sum + (s.obligation.lastPaidAmount || 0), 0);

// Type colors
const typeColors: Record<string, { bg: string; text: string }> = {
  iva: { bg: 'bg-blue-100', text: 'text-blue-700' },
  renta: { bg: 'bg-purple-100', text: 'text-purple-700' },
  ccss: { bg: 'bg-teal-100', text: 'text-teal-700' },
  patente: { bg: 'bg-orange-100', text: 'text-orange-700' },
  other: { bg: 'bg-gray-100', text: 'text-gray-700' }
};

const typeLabels: Record<string, string> = {
  iva: 'IVA',
  renta: 'Renta',
  ccss: 'CCSS',
  patente: 'Patente',
  other: 'Otro'
};

const frequencyLabels: Record<string, string> = {
  monthly: 'Mensual',
  quarterly: 'Trimestral',
  annual: 'Anual'
};

const formatDate = (date: Date) => date.toLocaleDateString('es-CR', { 
  day: 'numeric', 
  month: 'short', 
  year: 'numeric' 
});
---

<Layout title="Obligaciones Tributarias">
  <div class="min-h-screen flex">
    <!-- Sidebar -->
    <aside class="w-64 bg-landrover-keswick text-white flex-shrink-0 hidden lg:flex lg:flex-col">
      <div class="p-6">
        <h1 class="font-serif text-2xl font-semibold tracking-wide">Meraki</h1>
        <p class="text-landrover-limestone/60 text-xs mt-1">Financial Control</p>
      </div>
      
      <nav class="mt-4 flex-1">
        <a href="/mensual" class="flex items-center gap-3 px-6 py-3 text-landrover-limestone/80 hover:bg-white/5 hover:text-white transition-colors border-l-4 border-transparent">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
