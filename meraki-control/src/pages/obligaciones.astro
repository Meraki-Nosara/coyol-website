<script>
  async function markPaid(obligationId: string) {
    const amount = prompt('Monto pagado (opcional):');
    const today = new Date().toISOString().split('T')[0];
    
    try {
      const response = await fetch('/api/obligaciones', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'mark-paid',
          id: obligationId,
          date: today,
          amount: amount ? parseFloat(amount.replace(/[^0-9.]/g, '')) : null
        })
      });
      
      if (response.ok) {
        window.location.reload();
      } else {
        alert('Error al actualizar. Intente de nuevo.');
      }
    } catch (e) {
      alert('Error de conexión.');
    }
  }
  
  // Make function available globally
  (window as any).markPaid = markPaid;
</script>
