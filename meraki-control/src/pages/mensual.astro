          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="text-sm">Reports</span>
        </a>
        
        <a href="/informes" class="flex items-center gap-3 px-6 py-3 text-landrover-limestone/80 hover:bg-white/5 hover:text-white transition-colors border-l-4 border-transparent">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
          <span class="text-sm">PDF Reports</span>
        </a>
        
        <a href="/facturas" class="flex items-center gap-3 px-6 py-3 text-landrover-limestone/80 hover:bg-white/5 hover:text-white transition-colors border-l-4 border-transparent">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="text-sm">Facturas</span>
        </a>
        
        <a href="/tendencias" class="flex items-center gap-3 px-6 py-3 text-landrover-limestone/80 hover:bg-white/5 hover:text-white transition-colors border-l-4 border-transparent">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span class="text-sm">Trends</span>
        </a>
      </nav>
      
      <!-- User & Logout -->
      <div class="p-6 border-t border-white/10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-landrover-sand rounded-full flex items-center justify-center text-landrover-keswick font-semibold">
              AP
            </div>
            <div>
              <p class="text-sm font-medium">Angelina</p>
              <p class="text-xs text-landrover-limestone/60">Admin</p>
            </div>
          </div>
          <a href="/logout" class="text-landrover-limestone/60 hover:text-white transition-colors" title="Log out">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
          </a>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-auto">
      <!-- Mobile Header -->
      <header class="lg:hidden bg-landrover-keswick text-white p-4 flex items-center justify-between">
        <h1 class="font-serif text-xl font-semibold">Meraki</h1>
        <a href="/logout" class="text-landrover-limestone/80">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
        </a>
      </header>
      
      <!-- Header -->
      <header class="bg-white border-b border-landrover-arles/30 sticky top-0 z-40">
        <div class="px-4 lg:px-8 py-4 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
          <div>
            <h2 class="text-xl font-semibold text-landrover-santorini">Control Dashboard</h2>
            <p class="text-sm text-landrover-marine/60">Year to date • {allMonths.length} months</p>
          </div>
          
          <!-- Currency Toggle & Reports Button -->
          <div class="flex items-center gap-4">
            <div class="flex items-center gap-2">
              <span class="text-sm text-landrover-marine/60">Currency:</span>
              <div class="flex bg-landrover-limestone/50 rounded overflow-hidden">
                <a 
                  href="?currency=CRC" 
                  class={`px-4 py-2 text-sm font-medium transition-colors ${currency === 'CRC' ? 'bg-landrover-keswick text-white' : 'text-landrover-marine hover:bg-landrover-limestone'}`}
                >
                  CRC ₡
                </a>
                <a 
                  href="?currency=USD" 
                  class={`px-4 py-2 text-sm font-medium transition-colors ${currency === 'USD' ? 'bg-landrover-keswick text-white' : 'text-landrover-marine hover:bg-landrover-limestone'}`}
                >
                  USD $
                </a>
              </div>
              {currency === 'USD' && (
                <span class="text-xs text-landrover-marine/40">@ ₡{USD_RATE}/USD</span>
              )}
            </div>
            
            <a 
              href="/informes" 
              class="flex items-center gap-2 px-4 py-2 bg-landrover-keswick text-white rounded-lg hover:bg-landrover-coniston transition-colors text-sm font-medium shadow-sm"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Monthly Analysis Reports
            </a>
          </div>
        </div>
      </header>

      <div class="p-4 lg:p-8 space-y-6">
        
        <!-- Grand Total Card -->
        <div class="card p-5 lg:p-8 bg-landrover-keswick text-white">
          <div class="flex flex-col gap-4">
            <div>
              <p class="text-landrover-limestone/60 text-xs uppercase tracking-wider mb-1">Total Sales 2026</p>
              <p class="text-3xl lg:text-5xl font-semibold">{fmt(grandTotal)}</p>
              <p class="text-landrover-limestone/60 text-xs lg:text-sm mt-2">{yearTotals.customers.toLocaleString()} customers • {yearTotals.orders.toLocaleString()} orders</p>
            </div>
            <div class="flex gap-6 pt-2 border-t border-white/20">
              <div>
                <p class="text-landrover-limestone/60 text-xs uppercase">Food</p>
                <p class="text-lg lg:text-xl font-semibold">{fmt(yearTotals.food)}</p>
              </div>
              <div>
                <p class="text-landrover-limestone/60 text-xs uppercase">Bar</p>
                <p class="text-lg lg:text-xl font-semibold">{fmt(yearTotals.bar)}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Restaurant Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 lg:gap-4">
          {restaurantTotals.map(r => {
            const pct = grandTotal > 0 ? Math.round(r.totalSales / grandTotal * 100) : 0;
            return (
              <div class="card overflow-hidden">
                <div class="h-1.5 lg:h-2" style={`background-color: ${r.color}`}></div>
                <div class="p-4 lg:p-5">
                  <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center gap-3">
                      <img src={r.logo} alt={r.name} class={r.code === 'laluna' ? 'h-10 lg:h-14 w-auto' : 'h-8 lg:h-10 w-auto'} />
                    </div>
                    <span class="text-xs lg:text-sm text-landrover-marine/60 bg-landrover-limestone/30 px-2 py-0.5 rounded">{pct}%</span>
                  </div>
                  
                  <p class="text-2xl lg:text-3xl font-semibold text-landrover-santorini mb-3">
                    {fmt(r.totalSales)}
                  </p>
                  
                  <!-- Progress bar -->
                  <div class="h-1.5 lg:h-2 bg-landrover-limestone/50 rounded-full mb-3">
                    <div 
                      class="h-full rounded-full transition-all" 
                      style={`width: ${pct}%; background-color: ${r.color}`}
                    ></div>
                  </div>
                  
                  <div class="grid grid-cols-2 gap-x-4 gap-y-2 text-xs lg:text-sm">
                    <div>
                      <p class="text-landrover-marine/60">Food</p>
                      <p class="font-medium">{fmt(r.food)}</p>
                    </div>
                    <div>
                      <p class="text-landrover-marine/60">Bar</p>
                      <p class="font-medium">{fmt(r.bar)}</p>
                    </div>
                    <div>
                      <p class="text-landrover-marine/60">Customers</p>
                      <p class="font-medium">{r.customers > 0 ? r.customers.toLocaleString() : '-'}</p>
                    </div>
                    <div>
                      <p class="text-landrover-marine/60">Orders</p>
                      <p class="font-medium">{r.orders > 0 ? r.orders.toLocaleString() : '-'}</p>
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>

        <!-- Monthly Trend Chart (2026 vs 2025) -->
        {monthlyTotals.length > 0 && (
          <div class="card">
            <div class="px-4 lg:px-6 py-3 lg:py-4 border-b border-landrover-arles/30 flex items-center justify-between">
              <h3 class="font-semibold text-landrover-santorini text-sm lg:text-base">Monthly Trend: 2026 vs 2025</h3>
              <div class="flex items-center gap-4 text-xs">
                <div class="flex items-center gap-1.5">
                  <div class="w-3 h-3 rounded bg-landrover-sand/70"></div>
                  <span class="text-landrover-marine/60">2025</span>
                </div>
                <div class="flex items-center gap-1.5">
                  <div class="w-3 h-3 rounded bg-gradient-to-t from-landrover-keswick to-landrover-coniston"></div>
                  <span class="text-landrover-marine/60">2026</span>
                </div>
              </div>
            </div>
            
            <div class="p-4 lg:p-8">
              <!-- Graph with side-by-side bars -->
              <div class="flex items-end justify-around gap-4 lg:gap-8" style="height: 280px;">
                {monthlyTotals.map((m, i) => {
                  // Get corresponding 2025 month
                  const monthNum = m.month.split('-')[1];
                  const month2025 = data.monthly.filter(x => x.month === `2025-${monthNum}` && !x.partial);
                  const sales2025 = month2025.reduce((sum, x) => sum + x.totalSales, 0);
                  
                  // Calculate max for scaling (include both years)
                  const allSales = [...monthlyTotals.map(x => x.totalSales), sales2025];
                  const maxSales = Math.max(...allSales);
                  
                  const height2026 = maxSales > 0 ? Math.max(10, (m.totalSales / maxSales) * 100) : 50;
                  const height2025 = maxSales > 0 && sales2025 > 0 ? Math.max(10, (sales2025 / maxSales) * 100) : 0;
                  
                  // YoY change
                  const yoyChange = sales2025 > 0 ? Math.round((m.totalSales - sales2025) / sales2025 * 100) : 0;
                  
                  return (
                    <div class="flex-1 flex flex-col items-center max-w-40" style="height: 100%;">
                      <!-- Value labels -->
                      <div class="text-center mb-2 flex-shrink-0">
                        <p class="text-xs lg:text-sm font-bold text-landrover-santorini">{fmt(m.totalSales)}</p>
                        {sales2025 > 0 && (
                          <p class={`text-xs font-medium ${yoyChange >= 0 ? 'text-green-600' : 'text-red-500'}`}>
                            {yoyChange >= 0 ? '↑' : '↓'}{Math.abs(yoyChange)}% vs 2025
                          </p>
                        )}
                      </div>
                      
                      <!-- Side-by-side bars -->
                      <div class="w-full flex-1 flex items-end justify-center gap-1">
                        {/* 2025 bar (left) */}
                        {sales2025 > 0 && (
                          <div 
                            class="w-6 lg:w-8 rounded-t-lg bg-landrover-sand/70"
                            style={`height: ${height2025}%;`}
                          ></div>
                        )}
                        {/* 2026 bar (right) */}
                        <div 
                          class="w-6 lg:w-8 rounded-t-lg bg-gradient-to-t from-landrover-keswick to-landrover-coniston shadow-md"
                          style={`height: ${height2026}%;`}
                        ></div>
                      </div>
                      
                      <!-- Month label -->
                      <p class="text-xs lg:text-sm font-semibold text-landrover-marine mt-3 flex-shrink-0">
                        {formatMonth(m.month).split(' ')[0].slice(0, 3)}
                      </p>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        )}

        <!-- Year-over-Year Comparison (Q1) - Simple -->
        {q1_2025_total > 0 && (
          <div class="card p-5 lg:p-6">
            <div class="flex items-center justify-between">
              <h3 class="font-semibold text-landrover-santorini">Q1 vs Last Year</h3>
              <div class={`text-2xl lg:text-3xl font-bold ${q1_yoy_change >= 0 ? 'text-green-600' : 'text-red-500'}`}>
                {q1_yoy_change >= 0 ? '↑' : '↓'}{Math.abs(q1_yoy_change).toFixed(0)}%
              </div>
            </div>
            <p class="text-sm text-landrover-marine/60 mt-2">
              {fmt(q1_2026_total)} in 2026 vs {fmt(q1_2025_total)} in 2025
            </p>
          </div>
        )}

        <!-- Profitability Section - Simple Visual -->
        {totalGastos2026Q1 > 0 && (
          <div class="card p-5 lg:p-8">
            <h3 class="text-lg lg:text-xl font-semibold text-landrover-santorini mb-6">Q1 2026 Profit</h3>
            
            <!-- Big Numbers -->
            <div class="flex items-center justify-center gap-4 lg:gap-8 mb-8">
              <div class="text-center">
                <p class="text-3xl lg:text-5xl font-bold text-landrover-keswick">{fmt(totalSales2026Q1)}</p>
                <p class="text-sm text-landrover-marine/60 mt-1">Sales</p>
              </div>
              <div class="text-3xl lg:text-5xl text-landrover-marine/30">−</div>
              <div class="text-center">
                <p class="text-3xl lg:text-5xl font-bold text-red-500">{fmt(totalGastos2026Q1)}</p>
                <p class="text-sm text-landrover-marine/60 mt-1">Payments</p>
              </div>
              <div class="text-3xl lg:text-5xl text-landrover-marine/30">=</div>
              <div class="text-center">
                <p class="text-3xl lg:text-5xl font-bold text-green-600">{fmt(totalGrossProfit2026Q1)}</p>
                <p class="text-sm text-landrover-marine/60 mt-1">Profit</p>
              </div>
            </div>
            
            <!-- Visual Progress Bar -->
            <div class="mb-8">
              <div class="flex justify-between text-sm mb-2">
                <span class="text-landrover-marine/60">Margin</span>
                <span class="font-bold text-green-600 text-lg">{totalMargin2026Q1.toFixed(0)}%</span>
              </div>
              <div class="h-4 lg:h-6 bg-red-100 rounded-full overflow-hidden">
                <div 
                  class="h-full bg-green-500 rounded-full transition-all"
                  style={`width: ${totalMargin2026Q1}%`}
                ></div>
              </div>
              <div class="flex justify-between text-xs text-landrover-marine/40 mt-1">
                <span>Payments {(100 - totalMargin2026Q1).toFixed(0)}%</span>
                <span>Profit {totalMargin2026Q1.toFixed(0)}%</span>
              </div>
            </div>
            
            <!-- Per Restaurant - Simple Bars -->
            <div class="space-y-4">
              {profitability2026.map(r => {
                const name = r.code === 'laluna' ? 'La Luna' : r.code === 'esh' ? 'Esh' : 'Coyol';
                const colorMap: {[key: string]: string} = { esh: '#C4A67C', coyol: '#3D4F3D', laluna: '#A65D3F' };
                const color = colorMap[r.code] || '#666';
                
                return (
                  <div>
                    <div class="flex justify-between items-center mb-1">
                      <div class="flex items-center gap-2">
                        <div class="w-3 h-3 rounded" style={`background-color: ${color}`}></div>
                        <span class="font-medium">{name}</span>
                      </div>
                      <div class="flex items-center gap-4">
                        <span class="text-green-600 font-bold">{fmt(r.grossProfit)}</span>
                        <span class={`text-sm font-bold px-2 py-0.5 rounded ${r.margin >= 50 ? 'bg-green-100 text-green-700' : r.margin >= 30 ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700'}`}>
                          {r.margin.toFixed(0)}%
                        </span>
                      </div>
                    </div>
                    <div class="h-2 bg-red-100 rounded-full overflow-hidden">
                      <div 
                        class="h-full rounded-full"
                        style={`width: ${r.margin}%; background-color: ${color}`}
                      ></div>
                    </div>
                  </div>
                );
              })}
            </div>
            
            <p class="text-xs text-landrover-marine/40 mt-6 text-center">
              Payments = supplier purchases only (food, drinks, supplies)
            </p>
          </div>
        )}

        <!-- Two Pie Charts Side by Side -->
        <div class="grid grid-cols-2 gap-3 lg:gap-4">
          <!-- Food vs Drinks -->
          <div class="card">
            <div class="px-3 lg:px-6 py-2 lg:py-4 border-b border-landrover-arles/30">
              <h3 class="font-semibold text-landrover-santorini text-xs lg:text-base">Food vs Drinks</h3>
            </div>
            
            <div class="p-3 lg:p-6 flex flex-col lg:flex-row items-center justify-center gap-3 lg:gap-6">
              <div class="relative w-20 h-20 lg:w-32 lg:h-32">
                <svg viewBox="0 0 100 100" class="w-full h-full -rotate-90">
                  <circle cx="50" cy="50" r="40" fill="transparent" stroke="#3D4F3D" stroke-width="20"
                    stroke-dasharray={`${(yearTotals.food / (yearTotals.food + yearTotals.bar)) * 251.2} 251.2`}
                  />
                  <circle cx="50" cy="50" r="40" fill="transparent" stroke="#A65D3F" stroke-width="20"
                    stroke-dasharray={`${(yearTotals.bar / (yearTotals.food + yearTotals.bar)) * 251.2} 251.2`}
                    stroke-dashoffset={`-${(yearTotals.food / (yearTotals.food + yearTotals.bar)) * 251.2}`}
                  />
                </svg>
              </div>
              
              <div class="space-y-2 lg:space-y-3">
                <div class="flex items-center gap-2 lg:gap-3">
                  <div class="w-2 h-2 lg:w-3 lg:h-3 rounded bg-landrover-keswick"></div>
                  <div>
                    <p class="text-xs lg:text-sm font-medium">Food {Math.round(yearTotals.food / (yearTotals.food + yearTotals.bar) * 100)}%</p>
                    <p class="text-xs text-landrover-marine/60 hidden lg:block">{fmt(yearTotals.food)}</p>
                  </div>
                </div>
                <div class="flex items-center gap-2 lg:gap-3">
                  <div class="w-2 h-2 lg:w-3 lg:h-3 rounded bg-landrover-terracotta"></div>
                  <div>
                    <p class="text-xs lg:text-sm font-medium">Drinks {Math.round(yearTotals.bar / (yearTotals.food + yearTotals.bar) * 100)}%</p>
                    <p class="text-xs text-landrover-marine/60 hidden lg:block">{fmt(yearTotals.bar)}</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Cash vs Card -->
          <div class="card">
            <div class="px-3 lg:px-6 py-2 lg:py-4 border-b border-landrover-arles/30">
              <h3 class="font-semibold text-landrover-santorini text-xs lg:text-base">Cash vs Card</h3>
            </div>
            
            <div class="p-3 lg:p-6 flex flex-col lg:flex-row items-center justify-center gap-3 lg:gap-6">
              <div class="relative w-20 h-20 lg:w-32 lg:h-32">
                <svg viewBox="0 0 100 100" class="w-full h-full -rotate-90">
                  <circle cx="50" cy="50" r="40" fill="transparent" stroke="#2C3E50" stroke-width="20"
                    stroke-dasharray={`${(yearTotals.card / (yearTotals.card + yearTotals.cash)) * 251.2} 251.2`}
                  />
                  <circle cx="50" cy="50" r="40" fill="transparent" stroke="#C4A67C" stroke-width="20"
                    stroke-dasharray={`${(yearTotals.cash / (yearTotals.card + yearTotals.cash)) * 251.2} 251.2`}
                    stroke-dashoffset={`-${(yearTotals.card / (yearTotals.card + yearTotals.cash)) * 251.2}`}
                  />
                </svg>
              </div>
              
              <div class="space-y-2 lg:space-y-3">
                <div class="flex items-center gap-2 lg:gap-3">
                  <div class="w-2 h-2 lg:w-3 lg:h-3 rounded bg-landrover-marine"></div>
                  <div>
                    <p class="text-xs lg:text-sm font-medium">Card {Math.round(yearTotals.card / (yearTotals.card + yearTotals.cash) * 100)}%</p>
                    <p class="text-xs text-landrover-marine/60 hidden lg:block">{fmt(yearTotals.card)}</p>
                  </div>
                </div>
                <div class="flex items-center gap-2 lg:gap-3">
                  <div class="w-2 h-2 lg:w-3 lg:h-3 rounded bg-landrover-sand"></div>
                  <div>
                    <p class="text-xs lg:text-sm font-medium">Cash {Math.round(yearTotals.cash / (yearTotals.card + yearTotals.cash) * 100)}%</p>
                    <p class="text-xs text-landrover-marine/60 hidden lg:block">{fmt(yearTotals.cash)}</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Data Info -->
        <p class="text-xs text-landrover-marine/40 text-center">
          Last updated: {data.lastUpdated ? new Date(data.lastUpdated).toLocaleString('en-US') : 'N/A'}
        </p>
      </div>
    </main>
  </div>
</Layout>
