---
import Layout from '../layouts/Layout.astro';
import { loadMonthlyData, formatCurrency, formatMonth, USD_RATE } from '../lib/monthly-data';

const data = loadMonthlyData();
const allMonths = [...new Set(data.monthly.map(m => m.month))].sort();
const restaurants = ['esh', 'coyol', 'laluna'] as const;

// Get currency from URL param (default CRC)
const url = new URL(Astro.request.url);
const currency = (url.searchParams.get('currency') as 'CRC' | 'USD') || 'CRC';

// Helper to format with current currency
const fmt = (amount: number) => formatCurrency(amount, currency);

// Logo paths
const logos: Record<string, string> = {
  esh: '/images/logos/esh-black.png',
  coyol: '/images/logos/coyol-black.png',
  laluna: '/images/logos/laluna-black.png'
};

// Calculate totals BY RESTAURANT (2026 only)
const restaurantTotals = restaurants.map(code => {
  const restData = data.monthly.filter(m => m.restaurant === code && m.month.startsWith('2026') && !m.partial);
  return {
    code,
    name: data.restaurants[code]?.name || code,
    color: data.restaurants[code]?.color || '#666',
    logo: logos[code],
    totalSales: restData.reduce((sum, m) => sum + m.totalSales, 0),
    food: restData.reduce((sum, m) => sum + m.food, 0),
    bar: restData.reduce((sum, m) => sum + m.bar, 0),
    cash: restData.reduce((sum, m) => sum + m.cash, 0),
    card: restData.reduce((sum, m) => sum + m.card, 0),
    customers: restData.reduce((sum, m) => sum + m.customers, 0),
    orders: restData.reduce((sum, m) => sum + m.orders, 0),
    months: restData.length
  };
});

// Calculate totals per month (all restaurants combined) for trend chart
// Only include 2026 months
const months2026Only = allMonths.filter(m => m.startsWith('2026'));
const monthlyTotals = months2026Only
  .map(month => {
    const monthData = data.monthly.filter(m => m.month === month && !m.partial);
    return {
      month,
      totalSales: monthData.reduce((sum, m) => sum + m.totalSales, 0),
      restaurants: monthData.length
    };
  })
  .filter(m => m.totalSales > 0); // Only show months with data

// Year 2026 totals
const year2026 = data.monthly.filter(m => m.month.startsWith('2026') && !m.partial);
const yearTotals = {
  totalSales: year2026.reduce((sum, m) => sum + m.totalSales, 0),
  food: year2026.reduce((sum, m) => sum + m.food, 0),
  bar: year2026.reduce((sum, m) => sum + m.bar, 0),
  cash: year2026.reduce((sum, m) => sum + m.cash, 0),
  card: year2026.reduce((sum, m) => sum + m.card, 0),
  customers: year2026.reduce((sum, m) => sum + m.customers, 0),
  orders: year2026.reduce((sum, m) => sum + m.orders, 0),
  netReceipts: year2026.reduce((sum, m) => sum + m.netReceipts, 0)
};

// Year 2025 totals for comparison
const year2025 = data.monthly.filter(m => m.month.startsWith('2025') && !m.partial);
const year2025Totals = {
  totalSales: year2025.reduce((sum, m) => sum + m.totalSales, 0),
  food: year2025.reduce((sum, m) => sum + m.food, 0),
  bar: year2025.reduce((sum, m) => sum + m.bar, 0),
  cash: year2025.reduce((sum, m) => sum + m.cash, 0),
  card: year2025.reduce((sum, m) => sum + m.card, 0),
  customers: year2025.reduce((sum, m) => sum + m.customers, 0),
  orders: year2025.reduce((sum, m) => sum + m.orders, 0)
};

// Q1 comparison (Jan-Mar)
const q1_2026 = data.monthly.filter(m => ['2026-01', '2026-02', '2026-03'].includes(m.month) && !m.partial);
const q1_2025 = data.monthly.filter(m => ['2025-01', '2025-02', '2025-03'].includes(m.month) && !m.partial);
const q1_2026_total = q1_2026.reduce((sum, m) => sum + m.totalSales, 0);
const q1_2025_total = q1_2025.reduce((sum, m) => sum + m.totalSales, 0);
const q1_yoy_change = q1_2025_total > 0 ? ((q1_2026_total - q1_2025_total) / q1_2025_total * 100) : 0;

// Profitability data (2026 Q1)
const profitability2026 = restaurants.map(code => {
  const sales = q1_2026.filter(m => m.restaurant === code).reduce((sum, m) => sum + m.totalSales, 0);
  const gastos = q1_2026.filter(m => m.restaurant === code).reduce((sum, m) => sum + (m.gastos || 0), 0);
  const grossProfit = sales - gastos;
  const margin = sales > 0 ? (grossProfit / sales * 100) : 0;
  return { code, sales, gastos, grossProfit, margin };
});
const totalSales2026Q1 = profitability2026.reduce((sum, r) => sum + r.sales, 0);
const totalGastos2026Q1 = profitability2026.reduce((sum, r) => sum + r.gastos, 0);
const totalGrossProfit2026Q1 = totalSales2026Q1 - totalGastos2026Q1;
const totalMargin2026Q1 = totalSales2026Q1 > 0 ? (totalGrossProfit2026Q1 / totalSales2026Q1 * 100) : 0;

// Get which months we have data for in 2026
const months2026 = [...new Set(year2026.map(m => m.month.split('-')[1]))];

// Per-restaurant 2025 totals (only same months as 2026 data)
const restaurant2025Totals = restaurants.map(code => {
  const restData = data.monthly.filter(m => 
    m.restaurant === code && 
    m.month.startsWith('2025') && 
    months2026.includes(m.month.split('-')[1]) &&
    !m.partial
  );
  return {
    code,
    totalSales: restData.reduce((sum, m) => sum + m.totalSales, 0)
  };
});

// Recalculate 2025 totals for same period
const year2025SamePeriod = data.monthly.filter(m => 
  m.month.startsWith('2025') && 
  months2026.includes(m.month.split('-')[1]) &&
  !m.partial
);
const year2025SamePeriodTotal = year2025SamePeriod.reduce((sum, m) => sum + m.totalSales, 0);

// Grand total
const grandTotal = restaurantTotals.reduce((sum, r) => sum + r.totalSales, 0);
---

<Layout title="Control Dashboard">
  <div class="min-h-screen flex">
    <!-- Sidebar -->
    <aside class="w-64 bg-landrover-keswick text-white flex-shrink-0 hidden lg:flex lg:flex-col">
      <div class="p-6">
        <h1 class="font-serif text-2xl font-semibold tracking-wide">Meraki</h1>
        <p class="text-landrover-limestone/60 text-xs mt-1">Financial Control</p>
      </div>
      
      <nav class="mt-4 flex-1">
        <a href="/mensual" class="flex items-center gap-3 px-6 py-3 bg-white/10 text-white border-l-4 border-landrover-sand">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
