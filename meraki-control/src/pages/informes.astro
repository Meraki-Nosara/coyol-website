---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

// Scan for reports in public/reports folder
const reportsDir = path.join(process.cwd(), 'public/reports');
let reports: Array<{
  filename: string;
  title: string;
  period: string;
  year: number;
  month: number;
  url: string;
}> = [];

const MONTHS = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

if (fs.existsSync(reportsDir)) {
  // Prefer HTML files only to avoid duplicates
  const files = fs.readdirSync(reportsDir).filter(f => f.endsWith('.html'));
  
  reports = files.map(filename => {
    // Parse month-year from filename (e.g., january-2025-analysis.html)
    const monthMatch = filename.match(/^(january|february|march|april|may|june|july|august|september|october|november|december)-(\d{4})/i);
    
    if (!monthMatch) return null;
    
    const monthName = monthMatch[1].charAt(0).toUpperCase() + monthMatch[1].slice(1).toLowerCase();
    const year = parseInt(monthMatch[2]);
    const monthIndex = MONTHS.findIndex(m => m.toLowerCase() === monthName.toLowerCase());
    
    return {
      filename,
      title: `${monthName} ${year}`,
      period: `${monthName} ${year}`,
      year,
      month: monthIndex + 1,
      url: `/reports/${filename}`
    };
  })
  .filter(Boolean)
  .sort((a, b) => {
    // Sort by year desc, then month desc (newest first)
    if (a.year !== b.year) return b.year - a.year;
    return b.month - a.month;
  });
}

// Group by year
const reportsByYear = reports.reduce((acc, r) => {
  if (!acc[r.year]) acc[r.year] = [];
  acc[r.year].push(r);
  return acc;
}, {} as Record<number, typeof reports>);

const years = Object.keys(reportsByYear).map(Number).sort((a, b) => b - a);
---

<Layout title="Monthly Reports">
  <div class="min-h-screen flex">
    <!-- Sidebar -->
    <aside class="w-64 bg-landrover-keswick text-white flex-shrink-0 hidden lg:flex lg:flex-col">
      <div class="p-6">
        <h1 class="font-serif text-2xl font-semibold tracking-wide">Meraki</h1>
        <p class="text-landrover-limestone/60 text-xs mt-1">Financial Control</p>
      </div>
      
      <nav class="mt-4 flex-1">
        <a href="/mensual" class="flex items-center gap-3 px-6 py-3 text-landrover-limestone/80 hover:bg-white/5 hover:text-white transition-colors border-l-4 border-transparent">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
          <span class="text-sm">Dashboard</span>
        </a>
        
        <a href="/informes" class="flex items-center gap-3 px-6 py-3 bg-white/10 text-white border-l-4 border-landrover-sand">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="text-sm font-medium">Monthly Reports</span>
        </a>
        
        <a href="/reportes" class="flex items-center gap-3 px-6 py-3 text-landrover-limestone/80 hover:bg-white/5 hover:text-white transition-colors border-l-4 border-transparent">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="text-sm">Custom Reports</span>
        </a>
      </nav>
      
      <!-- User & Logout -->
      <div class="p-6 border-t border-white/10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-landrover-sand rounded-full flex items-center justify-center text-landrover-keswick font-semibold">
              AP
            </div>
            <div>
              <p class="text-sm font-medium">Angelina</p>
              <p class="text-xs text-landrover-limestone/60">Admin</p>
            </div>
          </div>
          <a href="/logout" class="text-landrover-limestone/60 hover:text-white transition-colors" title="Log out">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
          </a>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-auto">
      <!-- Mobile Header -->
      <header class="lg:hidden bg-landrover-keswick text-white p-4 flex items-center justify-between">
        <h1 class="font-serif text-xl font-semibold">Meraki</h1>
        <a href="/mensual" class="text-landrover-limestone/80">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </a>
      </header>
      
      <!-- Header -->
      <header class="bg-white border-b border-landrover-arles/30">
        <div class="px-4 lg:px-8 py-6">
          <h2 class="text-2xl font-semibold text-landrover-santorini">Monthly Reports</h2>
          <p class="text-sm text-landrover-marine/60 mt-1">Analysis reports sent by email</p>
        </div>
      </header>

      <div class="p-4 lg:p-8">
        
        {reports.length === 0 ? (
          <div class="card p-12 text-center">
            <svg class="w-16 h-16 mx-auto text-landrover-marine/20 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <h3 class="text-lg font-semibold text-landrover-santorini mb-2">No Reports Yet</h3>
            <p class="text-landrover-marine/60">Monthly analysis reports will appear here.</p>
          </div>
        ) : (
          <div class="space-y-8">
            {years.map(year => (
              <section>
                <h3 class="text-lg font-semibold text-landrover-santorini mb-4">{year}</h3>
                <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                  {reportsByYear[year].map(report => (
                    <a 
                      href={report.url}
                      target="_blank"
                      class="card p-4 hover:shadow-lg transition-all hover:scale-[1.02] group flex items-center gap-4"
                    >
                      <div class="w-10 h-10 bg-landrover-keswick/10 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-landrover-keswick/20 transition-colors">
                        <svg class="w-5 h-5 text-landrover-keswick" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                      </div>
                      <div class="flex-1 min-w-0">
                        <h4 class="font-medium text-landrover-santorini group-hover:text-landrover-keswick transition-colors">
                          {report.title}
                        </h4>
                        <p class="text-xs text-landrover-marine/50">Analysis</p>
                      </div>
                      <svg class="w-4 h-4 text-landrover-marine/30 group-hover:text-landrover-keswick transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  ))}
                </div>
              </section>
            ))}
          </div>
        )}

      </div>
    </main>
  </div>
</Layout>
